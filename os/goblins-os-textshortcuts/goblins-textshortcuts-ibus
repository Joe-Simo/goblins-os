                "import sys,time; sys.stdin.buffer.readline(); "
                f"sys.stdout.buffer.write(b'x'*{RUNTIME_RESPONSE_MAX_BYTES + 1}); "
                "sys.stdout.buffer.flush(); time.sleep(1)"
            ),
        ],
        response_timeout=0.5,
    )
    try:
        assert oversized_runtime.send({"type": "health"})["runtime_available"] is False
        assert oversized_runtime.last_response_ok() is False
    finally:
        oversized_runtime.close()

    unencodable_request_runtime = RuntimeBridge(
        argv=[
            sys.executable,
            "-u",
            "-c",
            "import sys,time; sys.stdin.buffer.readline(); time.sleep(1)",
        ],
        response_timeout=0.02,
    )
    try:
        response = unencodable_request_runtime.send(
            {"type": "health", "invalid": "\ud800"}
        )
        assert response["runtime_available"] is False
        assert unencodable_request_runtime.last_response_ok() is False
    finally:
        unencodable_request_runtime.close()

    huge_integer_frame = (
        b'{"handled":false,"operations":[],"x":' + (b"9" * 5000) + b"}\n"
    )
    huge_integer_runtime = RuntimeBridge(
        argv=[
            sys.executable,
            "-u",
            "-c",
            (
                "import os,sys,time; sys.stdin.buffer.readline(); "
                f"os.write(1,{huge_integer_frame!r}); time.sleep(1)"
            ),
        ],
        response_timeout=0.5,
    )
    try:
        response = huge_integer_runtime.send({"type": "health"})
        assert response["runtime_available"] is False
        assert huge_integer_runtime.last_response_ok() is False
    finally:
        huge_integer_runtime.close()

    malformed_runtime_responses = [
        {
            "handled": False,
            "operations": [
                {
                    "type": "update-preedit-text",
                    "text": "candidate",
                    "cursor_pos": 9,
                    "visible": True,
                }
            ],
        },
        {
            "handled": True,
            "operations": [
                {
                    "type": "delete-surrounding-text",
                    "offset": -3,
                    "n_chars": 3,
                    "expected_text": "omw",
                },
                {"type": "commit-text", "text": "must not commit"},
                {"type": "hide-preedit-text"},
            ],
            "error": "child reported failure",
        },
        {
            "handled": False,
            "operations": [{"type": "unknown-operation"}],
        },
        # Structurally valid for a boundary key, but never for Health.
        {
            "handled": True,
            "operations": [
                {
                    "type": "delete-surrounding-text",
                    "offset": -3,
                    "n_chars": 3,
                    "expected_text": "omw",
                },
                {"type": "commit-text", "text": "must not commit"},
                {"type": "hide-preedit-text"},
            ],
        },
    ]
    for malformed_response in malformed_runtime_responses:
        frame = (json.dumps(malformed_response, separators=(",", ":")) + "\n").encode(
            "utf-8"
        )
        malformed_runtime = RuntimeBridge(
            argv=[
                sys.executable,
                "-u",
                "-c",
                (
                    "import os,sys,time; sys.stdin.buffer.readline(); "
                    f"os.write(1,{frame!r}); time.sleep(1)"
                ),
            ],
            response_timeout=0.5,
        )
        try:
            response = malformed_runtime.send({"type": "health"})
            assert response["runtime_available"] is False
            assert response["operations"] == [{"type": "hide-preedit-text"}]
            assert malformed_runtime.last_response_ok() is False
        finally:
            malformed_runtime.close()


def _run_ibus() -> int:
    import gi

    gi.require_version("IBus", "1.0")
    from gi.repository import GLib, IBus

    IBus.init()

    class GoblinsTextShortcutsEngine(IBus.Engine):
        def __init__(self) -> None:
            super().__init__()
            self._runtime_status = RuntimeStatusPublisher()
            self._bridge = RuntimeBridge(
                health_callback=self._runtime_status.runtime_transport,
            )
            self._configured_runtime_generation = 0
            self._table = ShortcutTableBridge()
            self._candidate_state = CandidateMetadataState()
            self._proof_ledger = _proof_event_sink_from_env()
            self._has_cursor_rect = False
            self._lookup_table_capability = False
            self._surrounding_text_capability = False
            self._enabled = False
            self._effective_purpose = min(SENSITIVE_INPUT_PURPOSES)
            self._sensitive_content = True
            self._surrounding_guard = SurroundingTextCommitGuard()
            self._surrounding_text_cache = FocusBoundSurroundingTextCache()
            self._native_candidate_popup = NativeIbusLookupRenderer(
                self,
                IBus,
                self._proof_ledger,
                has_cursor_rect=lambda: self._has_cursor_rect,
                lookup_table_capability=lambda: self._lookup_table_capability,
            )
            self._candidate_render = CandidateBubbleRenderIntentController(
                sink=self._native_candidate_popup,
            )
            self._health_source = GLib.timeout_add_seconds(
                RUNTIME_HEALTH_INTERVAL_SECONDS,
                self._runtime_health_tick,
            )

        def do_enable(self) -> None:
            self._record_callback("enable")
            self._enabled = True
            self._runtime_status.set_enabled(True)
            self._surrounding_guard.reset()
            self._invalidate_surrounding_snapshot()
            self._refresh_content_type("enable")
            if not self._sensitive_content:
                self._request_surrounding_text()

        def do_disable(self) -> None:
            self._record_callback("disable")
            self._enabled = False
            self._sensitive_content = True
            self._effective_purpose = min(SENSITIVE_INPUT_PURPOSES)
            self._surrounding_text_cache.end_focus()
            self._runtime_status.set_enabled(False)
            self._runtime_status.set_focused(False)
            self._clear_candidate_ui("disabled")
            self._reset_runtime_child("disable")

        def do_focus_in(self) -> None:
            self._record_callback("focus-in")
            self._surrounding_text_cache.begin_focus()
            self._runtime_status.set_focused(True)
            self._surrounding_guard.reset()
            self._runtime_status.set_snapshot_valid(False)
            purpose = self._refresh_content_type("focus-in")
            self._synchronize_runtime()
            response = self._bridge.send(
                _content_purpose_request("focus-in", purpose)
            )
            self._apply_runtime_response("focus-in", None, response, None)
            if not self._sensitive_content:
                self._request_surrounding_text()

        def do_focus_out(self) -> None:
            self._record_callback("focus-out")
            self._surrounding_text_cache.end_focus()
            self._runtime_status.set_focused(False)
            self._sensitive_content = True
            self._effective_purpose = min(SENSITIVE_INPUT_PURPOSES)
            self._clear_candidate_ui("focus-out")
            response = self._bridge.send({"type": "focus-out"})
            self._apply_runtime_response("focus-out", None, response, None)
            self._clear_candidate_ui("focus-out")

        def do_reset(self) -> None:
            self._record_callback("reset")
            self._invalidate_surrounding_snapshot()
            self._clear_candidate_ui("reset")
            self._reset_runtime_child("reset")

        def do_set_content_type(self, purpose: int, hints: int) -> None:
            self._record_callback("set-content-type")
            effective = self._update_content_type(
                purpose,
                hints,
                "sensitive-content-type",
                invalidate_snapshot=True,
                record=True,
            )
            self._reset_runtime_child("content-type-changed")
            response = self._bridge.send(
                _content_purpose_request("content-purpose-changed", effective)
            )
            self._apply_runtime_response("set-content-type", None, response, None)
            if not self._sensitive_content:
                self._request_surrounding_text()

        def do_set_cursor_location(self, x: int, y: int, width: int, height: int) -> None:
            self._record_callback("set-cursor-location")
            self._has_cursor_rect = all(
                isinstance(value, int) for value in (x, y, width, height)
            ) and width >= 0 and height > 0
            if self._proof_ledger is not None:
                self._proof_ledger.cursor_location(self._has_cursor_rect)

        def do_set_capabilities(self, capabilities: int) -> None:
            self._record_callback("set-capabilities")
            capability_type = getattr(IBus, "Capabilite", None)
            lookup_mask = int(
                getattr(
                    capability_type,
                    "LOOKUP_TABLE",
                    IBUS_CAP_LOOKUP_TABLE_FALLBACK,
                )
            )
            surrounding_mask = int(
                getattr(
                    capability_type,
                    "SURROUNDING_TEXT",
                    IBUS_CAP_SURROUNDING_TEXT_FALLBACK,
                )
            )
            self._lookup_table_capability = bool(int(capabilities) & lookup_mask)
            self._surrounding_text_capability = bool(
                int(capabilities) & surrounding_mask
            )
            self._runtime_status.set_surrounding_text_supported(
                self._surrounding_text_capability
            )
            lost_support = self._surrounding_guard.set_supported(
                self._surrounding_text_capability
            )
            if not self._surrounding_text_capability:
                self._invalidate_surrounding_snapshot()
            if self._proof_ledger is not None:
                self._proof_ledger.capabilities(
                    self._lookup_table_capability,
                    self._surrounding_text_capability,
                )
            if lost_support:
                self._clear_candidate_ui("surrounding-capability-lost")
                self._reset_runtime_child("surrounding-capability-lost")
            elif self._surrounding_text_capability and not self._sensitive_content:
                self._request_surrounding_text()

        def do_set_surrounding_text(
            self,
            text: Any,
            cursor_index: int,
            anchor_pos: int,
        ) -> None:
            self._record_callback("set-surrounding-text")
            if (
                not self._enabled
                or self._sensitive_content
                or not self._surrounding_text_capability
                or not self._runtime_status.is_focused()
            ):
                self._invalidate_surrounding_snapshot()
                self._surrounding_guard.reset()
                return
            snapshot = _normalize_surrounding_text(text, cursor_index, anchor_pos)
            if snapshot is None:
                self._invalidate_surrounding_snapshot()
                self._clear_candidate_ui("invalid-surrounding-snapshot")
                self._reset_runtime_child("invalid-surrounding-snapshot")
                return
            if not self._surrounding_text_cache.observe(snapshot):
                self._invalidate_surrounding_snapshot()
                self._surrounding_guard.reset()
                return
            self._runtime_status.set_snapshot_valid(True)
            if self._surrounding_guard.observe_surrounding(snapshot):
                self._clear_candidate_ui("surrounding-text-changed")
                self._reset_runtime_child("surrounding-text-changed")
            elif (
                self._configured_runtime_generation
                == self._bridge.runtime_generation()
                and self._bridge.last_response_ok()
            ):
                self._runtime_status.protocol_ready(
                    self._configured_runtime_generation
                )

        def do_process_key_event(self, keyval: int, keycode: int, state: int) -> bool:
            del keycode
            self._record_callback("process-key-event")
            self._refresh_content_type("process-key-event")
            if (
                not self._enabled
                or self._sensitive_content
                or not self._surrounding_text_capability
            ):
                self._runtime_status.set_snapshot_valid(False)
                self._clear_candidate_ui("key-refused-without-safe-context")
                return False
            self._synchronize_runtime()
            table_changed, table_applied = _send_table_changed_if_needed(
                self._table,
                self._bridge,
                self,
                IBus.Text.new_from_string,
                self._candidate_state,
                self._candidate_render,
                self._proof_ledger,
            )
            if not table_applied:
                self._clear_candidate_ui("table-change-application-failed")
                self._invalidate_surrounding_snapshot()
                self._bridge.send({"type": "reset"})
                self._request_surrounding_text()
                return False
            if table_changed:
                self._surrounding_guard.reset()
            request = _key_request(keyval, state, IBus)
            snapshot = self._current_surrounding_text()
            if snapshot is None:
                self._clear_candidate_ui("surrounding-snapshot-unavailable")
                self._reset_runtime_child("surrounding-snapshot-unavailable")
                self._request_surrounding_text()
                return False
            if self._surrounding_guard.prepare_key(request, snapshot):
                self._clear_candidate_ui("surrounding-edit-anchor-reset")
                self._reset_runtime_child("surrounding-edit-anchor-reset")
            response = self._bridge.send(request)
            response = self._apply_runtime_response(
                "process-key-event",
                request,
                response,
                snapshot,
            )
            return bool(response.get("handled", False))

        def do_candidate_clicked(self, index: int, button: int, state: int) -> None:
            del state
            self._record_callback("candidate-clicked")
            self._refresh_content_type("candidate-clicked")
            if (
                not self._enabled
                or self._sensitive_content
                or not self._surrounding_text_capability
            ):
                self._clear_candidate_ui("candidate-click-refused")
                return
            request = _candidate_click_request(index, button)
            if request is None:
                self._clear_candidate_ui("candidate-click-invalid")
                return
            snapshot = self._current_surrounding_text()
            if not self._surrounding_guard.prepare_candidate_accept(snapshot):
                self._clear_candidate_ui("candidate-edit-anchor-invalid")
                self._reset_runtime_child("candidate-edit-anchor-invalid")
                return
            response = self._bridge.send(request)
            self._apply_runtime_response(
                "candidate-clicked",
                request,
                response,
                snapshot,
            )

        def _apply_runtime_response(
            self,
            callback: str,
            request: dict[str, Any] | None,
            response: dict[str, Any],
            snapshot: SurroundingTextSnapshot | None,
        ) -> dict[str, Any]:
            effective = self._surrounding_guard.validate_response(
                request,
                response,
                snapshot,
            )
            if effective is not response:
                self._clear_candidate_ui("runtime-response-guard-rejected")
                self._invalidate_surrounding_snapshot()
                self._bridge.send({"type": "reset"})
            elif not _runtime_response_ok(response):
                self._clear_candidate_ui("runtime-unavailable")
                self._invalidate_surrounding_snapshot()
            self._record_operations(callback, effective)
            applied = _apply_response_operations_with_render_intent(
                self,
                effective,
                IBus.Text.new_from_string,
                self._candidate_state,
                self._candidate_render,
            )
            if not applied:
                self._clear_candidate_ui("runtime-operation-application-failed")
                self._invalidate_surrounding_snapshot()
                self._bridge.send({"type": "reset"})
                if not _response_has_destructive_replacement(effective):
                    effective = _passthrough_response()
            if (
                applied
                and effective is response
                and _runtime_response_ok(effective)
                and self._configured_runtime_generation
                == self._bridge.runtime_generation()
            ):
                self._runtime_status.protocol_ready(
                    self._configured_runtime_generation
                )
            return effective

        def _synchronize_runtime(self) -> bool:
            if not self._enabled:
                return False
            generation = self._bridge.runtime_generation()
            if (
                generation > 0
                and generation == self._configured_runtime_generation
                and self._bridge.last_response_ok()
            ):
                return True
            if self._configured_runtime_generation or self._candidate_state.current is not None:
                self._clear_candidate_ui("runtime-generation-changed")
            self._invalidate_surrounding_snapshot()
            self._configured_runtime_generation = 0
            self._table.invalidate()
            self._surrounding_guard.reset()
            table_changed, table_applied = _send_table_changed_if_needed(
                self._table,
                self._bridge,
                self,
                IBus.Text.new_from_string,
                self._candidate_state,
                self._candidate_render,
                self._proof_ledger,
            )
            if not table_applied:
                self._clear_candidate_ui("table-change-application-failed")
                self._invalidate_surrounding_snapshot()
                self._bridge.send({"type": "reset"})
                return False
            table_ready = table_changed and self._bridge.last_response_ok()
            response = self._bridge.send(
                _content_purpose_request("focus-in", self._effective_purpose)
            )
            self._apply_runtime_response("runtime-synchronize", None, response, None)
            generation = self._bridge.runtime_generation()
            if (
                table_ready
                and _runtime_response_ok(response)
                and self._bridge.last_response_ok()
                and generation > 0
            ):
                self._configured_runtime_generation = generation
                self._runtime_status.protocol_ready(generation)
                return True
            return False

        def _runtime_health_tick(self) -> bool:
            if not self._runtime_status.is_focused() or not self._enabled:
                return True
            response = self._bridge.send({"type": "health"})
            if not _runtime_response_ok(response):
                self._configured_runtime_generation = 0
                self._clear_candidate_ui("runtime-health-failed")
                self._invalidate_surrounding_snapshot()
                return True
            if self._configured_runtime_generation != self._bridge.runtime_generation():
                self._clear_candidate_ui("runtime-generation-changed")
                self._synchronize_runtime()
            else:
                self._runtime_status.protocol_ready(
                    self._configured_runtime_generation
                )
            return True

        def _reset_runtime_child(self, callback: str) -> None:
            self._clear_candidate_ui(callback)
            self._invalidate_surrounding_snapshot()
            response = self._bridge.send({"type": "reset"})
            self._apply_runtime_response(callback, None, response, None)
            self._request_surrounding_text()

        def _current_surrounding_text(self) -> SurroundingTextSnapshot | None:
            if (
                not self._enabled
                or self._sensitive_content
                or not self._surrounding_text_capability
            ):
                self._invalidate_surrounding_snapshot()
                return None
            snapshot = self._surrounding_text_cache.current()
            self._runtime_status.set_snapshot_valid(snapshot is not None)
            return snapshot

        def _request_surrounding_text(self) -> None:
            if (
                not self._enabled
                or self._sensitive_content
                or not self._surrounding_text_capability
                or not self._runtime_status.is_focused()
            ):
                self._runtime_status.set_snapshot_valid(False)
                return
            try:
                self.get_surrounding_text()
            except (AttributeError, TypeError, ValueError, RuntimeError):
                self._runtime_status.set_snapshot_valid(False)
                return

        def do_destroy(self) -> None:
            self._enabled = False
            self._surrounding_text_cache.end_focus()
            self._runtime_status.set_enabled(False)
            self._runtime_status.set_focused(False)
            if self._health_source:
                GLib.source_remove(self._health_source)
                self._health_source = 0
            self._clear_candidate_ui("destroyed")
            self._bridge.close()
            super().do_destroy()

        def _clear_candidate_ui(self, reason: str) -> None:
            self._surrounding_guard.reset()
            try:
                self.hide_preedit_text()
            except (AttributeError, TypeError, ValueError, RuntimeError):
                pass
            self._candidate_render.clear(self._candidate_state, reason)

        def _update_content_type(
            self,
            purpose: Any,
            hints: Any,
            reason: str,
            *,
            invalidate_snapshot: bool,
            record: bool,
        ) -> int:
            effective = _effective_content_purpose(purpose, hints, IBus)
            sensitive = effective in SENSITIVE_INPUT_PURPOSES
            sensitivity_changed = sensitive != self._sensitive_content
            self._effective_purpose = effective
            self._sensitive_content = sensitive
            if record:
                self._record_content_purpose(sensitive)
            if sensitivity_changed or invalidate_snapshot:
                self._surrounding_guard.reset()
                self._invalidate_surrounding_snapshot()
            if sensitive:
                self._clear_candidate_ui(reason)
            elif sensitivity_changed and self._enabled:
                self._request_surrounding_text()
            return effective

        def _invalidate_surrounding_snapshot(self) -> None:
            self._surrounding_text_cache.invalidate()
            self._runtime_status.set_snapshot_valid(False)

        def _refresh_content_type(self, reason: str) -> int:
            try:
                content_type = self.get_content_type()
                if not isinstance(content_type, (tuple, list)) or len(content_type) != 2:
                    raise TypeError("invalid IBus content type")
                purpose, hints = content_type
            except (AttributeError, TypeError, ValueError, RuntimeError):
                purpose = min(SENSITIVE_INPUT_PURPOSES)
                hints = 0
            return self._update_content_type(
                purpose,
                hints,
                reason,
                invalidate_snapshot=False,
                record=False,
            )

        def _record_callback(self, callback: str) -> None:
            if self._proof_ledger is not None:
                self._proof_ledger.callback(callback)

        def _record_operations(self, callback: str, response: dict[str, Any]) -> None:
            if self._proof_ledger is not None:
                self._proof_ledger.operations(callback, response)

        def _record_content_purpose(self, sensitive_purpose: bool) -> None:
            if self._proof_ledger is not None:
                self._proof_ledger.content_purpose(sensitive_purpose)

        def _purpose(self) -> int:
            return self._refresh_content_type("content-type-query")

    bus = IBus.Bus()
    if not bus.is_connected():
        print("goblins-textshortcuts-ibus: IBus bus is not connected", file=sys.stderr)
        return 0

    loop = GLib.MainLoop()
    bus.connect("disconnected", lambda *_args: loop.quit())
    factory = IBus.Factory.new(bus.get_connection())
    factory.add_engine(ENGINE_NAME, GoblinsTextShortcutsEngine)
    bus.request_name(COMPONENT_NAME, 0)
    loop.run()
    return 0


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Goblins OS Text Shortcuts IBus adapter")
    parser.add_argument("--capability-check", action="store_true")
    parser.add_argument("--gi-adapter-contract-self-test", action="store_true")
    parser.add_argument("--adapter-callback-ledger-self-test", action="store_true")
    parser.add_argument("--candidate-bubble-render-intent-self-test", action="store_true")
    parser.add_argument("--native-ibus-lookup-renderer-self-test", action="store_true")
    parser.add_argument("--candidate-bubble-layout-self-test", action="store_true")
    parser.add_argument("--candidate-bubble-frame-self-test", action="store_true")
    parser.add_argument("--overlay-intent-self-test", action="store_true")
    parser.add_argument("--runtime-self-test", action="store_true")
    parser.add_argument("--self-test", action="store_true")
    args = parser.parse_args(argv)
    if args.capability_check:
        print(json.dumps(capability_payload(), sort_keys=True))
        return 0
    if args.gi_adapter_contract_self_test:
        print(json.dumps(_run_gi_adapter_contract_self_test(), sort_keys=True))
        return 0
    if args.adapter_callback_ledger_self_test:
        print(json.dumps(_run_adapter_callback_ledger_self_test(), sort_keys=True))
        return 0
    if args.candidate_bubble_render_intent_self_test:
        print(json.dumps(_run_candidate_bubble_render_intent_self_test(), sort_keys=True))
        return 0
    if args.native_ibus_lookup_renderer_self_test:
        print(json.dumps(_run_native_ibus_lookup_renderer_self_test(), sort_keys=True))
        return 0
    if args.candidate_bubble_layout_self_test:
        print(json.dumps(_run_candidate_bubble_layout_self_test(), sort_keys=True))
        return 0
    if args.candidate_bubble_frame_self_test:
        print(json.dumps(_run_candidate_bubble_frame_self_test(), sort_keys=True))
        return 0
    if args.overlay_intent_self_test:
        print(json.dumps(_run_overlay_intent_self_test(), sort_keys=True))
        return 0
    if args.runtime_self_test:
        _run_runtime_self_test()
        print("goblins_textshortcuts_ibus_runtime_selftest ok")
        return 0
    if args.self_test:
        _run_self_test()
        print("goblins_textshortcuts_ibus_adapter_selftest ok")
        return 0
    return _run_ibus()


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
