COPY os/dconf/ /etc/dconf/
COPY os/gdm/custom.conf /etc/gdm/custom.conf
COPY os/accountsservice/goblin /var/lib/AccountsService/users/goblin

RUN grep -Fxq 'AutomaticLoginEnable=True' /etc/gdm/custom.conf \
    && grep -Fxq 'AutomaticLogin=goblin' /etc/gdm/custom.conf \
    && grep -Fxq 'TimedLoginEnable=True' /etc/gdm/custom.conf \
    && grep -Fxq 'TimedLogin=goblin' /etc/gdm/custom.conf \
    && grep -Fxq 'TimedLoginDelay=0' /etc/gdm/custom.conf

# Product identity: this is Goblins OS, not Fedora. Rebrand os-release (NAME /
# PRETTY_NAME / VARIANT) while keeping ID=fedora + the version intact so dnf and
# bootc still resolve the platform correctly.
RUN sed -i \
      -e 's/^NAME=.*/NAME="Goblins OS"/' \
      -e 's/^PRETTY_NAME=.*/PRETTY_NAME="Goblins OS"/' \
      -e '/^VARIANT=/d' -e '/^VARIANT_ID=/d' \
      /usr/lib/os-release \
    && printf 'VARIANT="Goblins OS"\nVARIANT_ID=goblins-os\n' >> /usr/lib/os-release

# Boot identity: the Goblins OS Plymouth splash replaces Fedora's. The mark is
# the shipped Goblins mark; setting the default theme writes plymouthd.conf (the
# initramfs regen happens at deploy).
RUN cp /usr/share/goblins-os/brand/anaconda/sidebar-logo.png \
        /usr/share/plymouth/themes/goblins-os/logo.png \
    && plymouth-set-default-theme goblins-os

# Themed GNOME stock utilities: GoblinsOS icon theme ships source-owned graphite
# tiles and a one-weight symbolic family, inheriting Adwaita for everything else.
RUN (gtk4-update-icon-cache -f /usr/share/icons/GoblinsOS \
        || gtk-update-icon-cache -f /usr/share/icons/GoblinsOS || true)

# Shell-extension keybindings live in the extension's GSettings schema so Mutter
# owns the shortcuts directly.
RUN glib-compile-schemas /usr/share/gnome-shell/extensions/goblins-wm@goblins.os/schemas

# Goblins-owned system schemas (Focus modes, …) compiled into the shared schema set.
RUN glib-compile-schemas /usr/share/glib-2.0/schemas

# Rebrand the Anaconda installer chrome (the disk installer the ISO boots into):
# recolor the Fedora-blue sidebar base (#51a2da) to Goblins ink so the sidebar
# reads dark and on-brand; the dark sidebar art + white mark are COPYed above.
RUN sed -i 's/#51a2da/#0b0b0f/g' /usr/share/anaconda/pixmaps/fedora.css 2>/dev/null || true

