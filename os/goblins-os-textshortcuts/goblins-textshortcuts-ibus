        ) -> None:
            del text, cursor_pos
            if visible:
                self.visible_preedit_updates += 1

        def hide_preedit_text(self) -> None:
            return None

        def delete_surrounding_text(self, offset: int, n_chars: int) -> None:
            del offset, n_chars

