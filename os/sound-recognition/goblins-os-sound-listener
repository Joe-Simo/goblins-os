#!/usr/bin/env python3
"""Goblins OS Sound Recognition listener boundary.

This is the session-user process boundary for future on-device sound
classification. The classifier loop is intentionally not active in this source
slice: until model provisioning, inference dependencies, capture integration,
and qemu proof land together, the listener reports a clear not-ready capability
and exits without capturing microphone audio.
"""

from __future__ import annotations

import argparse
import importlib.util
import json
import os
import shutil
from pathlib import Path
from typing import Any


DEFAULT_MODEL_DIR = "/var/lib/goblins-os/sound-recognition"
MODEL_DIR_ENV = "GOBLINS_OS_SOUND_RECOGNITION_MODEL_DIR"
CAPTURE_BIN_ENV = "GOBLINS_OS_SOUND_RECOGNITION_CAPTURE_BIN"
DEFAULT_CAPTURE_BIN = "arecord"
DETAIL = (
    "Sound Recognition listener is installed, but the live classifier loop is "
    "still pending model provisioning and CI/qemu proof. "
    "No microphone audio is captured by this listener yet."
)
RELIABILITY_DETAIL = (
    "This recognizes sounds approximately and on-device only. Do not rely on it "
    "in emergencies or high-risk situations."
)
DEFAULT_DEBOUNCE_MS = 30_000
NOTIFICATION_APP_NAME = "Goblins OS Sound Recognition"
NOTIFICATION_APP_ID = "org.goblins.OS.SoundRecognition"
NOTIFICATION_APP_ICON = "goblins-os"
NOTIFICATION_DESKTOP_ENTRY = "org.goblins.OS.Settings"
NOTIFICATION_CATEGORY_HINT = "device.sound-recognition"

SOUND_CATEGORIES: dict[str, dict[str, Any]] = {
    "smoke-fire-alarm": {
        "name": "Smoke or fire alarm",
        "group": "Safety",
        "audioset_classes": ["Smoke detector, smoke alarm", "Fire alarm"],
    },
    "siren": {
        "name": "Siren",
        "group": "Safety",
        "audioset_classes": ["Siren", "Emergency vehicle"],
    },
    "doorbell": {"name": "Doorbell", "group": "Home", "audioset_classes": ["Doorbell"]},
    "knock": {"name": "Knock", "group": "Home", "audioset_classes": ["Knock"]},
    "baby-crying": {
        "name": "Baby crying",
        "group": "People",
        "audioset_classes": ["Baby cry, infant cry"],
    },
    "dog-bark": {"name": "Dog bark", "group": "Animals", "audioset_classes": ["Bark"]},
    "car-horn": {
        "name": "Car horn",
        "group": "Outside",
        "audioset_classes": ["Vehicle horn, car horn, honking"],
    },
    "appliance-beep": {
        "name": "Appliance beep",
        "group": "Home",
        "audioset_classes": ["Beep, bleep", "Microwave oven", "Alarm clock"],
    },
    "running-water": {
        "name": "Running water",
        "group": "Home",
        "audioset_classes": ["Water", "Liquid", "Pour", "Splash, splatter"],
    },
    "shouting": {"name": "Shouting", "group": "People", "audioset_classes": ["Shout", "Yell"]},
}


def _model_dir() -> Path:
    return Path(os.environ.get(MODEL_DIR_ENV, DEFAULT_MODEL_DIR))


def _capture_bin() -> str:
    return os.environ.get(CAPTURE_BIN_ENV, DEFAULT_CAPTURE_BIN)


def _module_present(name: str) -> bool:
    return importlib.util.find_spec(name) is not None


def _first_model(path: Path) -> str | None:
    try:
        models = sorted(
            candidate
            for candidate in path.iterdir()
            if candidate.is_file() and candidate.suffix == ".onnx"
        )
    except OSError:
        return None
    return str(models[0]) if models else None


def _normalize_audioset_label(value: str) -> str:
    return "".join(ch.lower() for ch in value if ch.isascii() and ch.isalnum())


def _normalize_sensitivity(value: str) -> str:
    return value if value in {"low", "medium", "high"} else "medium"


def _clamp_confidence(value: float) -> float:
    if value != value:
        return 0.70
    return round(min(0.95, max(0.30, value)), 2)


def decision_threshold(sensitivity: str, min_confidence: float) -> float:
    base = _clamp_confidence(min_confidence)
    normalized = _normalize_sensitivity(sensitivity)
    if normalized == "low":
        adjusted = base + 0.10
    elif normalized == "high":
        adjusted = base - 0.10
    else:
        adjusted = base
    return _clamp_confidence(adjusted)


def _category_matches(category_id: str, audioset_class: str) -> bool:
    category = SOUND_CATEGORIES.get(category_id)
    if category is None:
        return False
    needle = _normalize_audioset_label(audioset_class)
    if not needle:
        return False
    for candidate in category["audioset_classes"]:
        normalized = _normalize_audioset_label(candidate)
        if normalized == needle or needle in normalized or normalized in needle:
            return True
    return False


def evaluate_detection_window(
    scores: list[dict[str, Any]],
    *,
    enabled_sound_ids: list[str],
    sensitivity: str,
    min_confidence: float,
    now_ms: int,
    last_alerts: dict[str, int] | None = None,
    debounce_ms: int = DEFAULT_DEBOUNCE_MS,
    alert_sound: bool = False,
    alert_flash: bool = False,
    notify_in_lock_screen: bool = False,
) -> dict[str, Any]:
    enabled = [
        sound_id for sound_id in enabled_sound_ids if sound_id in SOUND_CATEGORIES
    ]
    if not enabled:
        return {"alert": None, "suppressed_reason": "no-enabled-sounds"}

    threshold = decision_threshold(sensitivity, min_confidence)
    best: tuple[str, dict[str, Any]] | None = None
    for score in scores:
        try:
            audioset_class = str(score["audioset_class"])
            confidence = float(score["confidence"])
        except (KeyError, TypeError, ValueError):
            continue
        if confidence != confidence or confidence < threshold:
            continue
        for sound_id in enabled:
            if _category_matches(sound_id, audioset_class):
                if best is None or confidence > float(best[1]["confidence"]):
                    best = (
                        sound_id,
                        {
                            "audioset_class": audioset_class,
                            "confidence": confidence,
                        },
                    )

    if best is None:
        return {"alert": None, "suppressed_reason": "below-threshold-or-unmapped"}

    sound_id, score = best
    if last_alerts and now_ms - int(last_alerts.get(sound_id, -debounce_ms)) < debounce_ms:
        return {"alert": None, "suppressed_reason": "debounced"}

    category = SOUND_CATEGORIES[sound_id]
    confidence = max(0.0, min(1.0, float(score["confidence"])))
    percent = round(confidence * 100)
    notification_title = f"Sound recognized: {category['name']}"
    notification_body = (
        f"{category['name']} matched \"{score['audioset_class']}\" "
        f"at {percent}% confidence. {RELIABILITY_DETAIL}"
    )
    return {
        "alert": {
            "category_id": sound_id,
            "category_name": category["name"],
            "audioset_class": score["audioset_class"],
            "confidence": round(confidence, 2),
            "notification_title": notification_title,
            "notification_body": notification_body,
            "alert_sound": alert_sound,
            "alert_flash": alert_flash,
            "delivery_plan": build_notification_delivery_plan(
                sound_id,
                notification_title,
                notification_body,
                alert_sound=alert_sound,
                alert_flash=alert_flash,
                show_on_lock_screen=notify_in_lock_screen,
            ),
        },
        "suppressed_reason": None,
    }


def _notification_urgency(category_id: str) -> str:
    category = SOUND_CATEGORIES.get(category_id)
    if category and category.get("group") == "Safety":
        return "critical"
    return "normal"


def build_notification_delivery_plan(
    category_id: str,
    summary: str,
    body: str,
    *,
    alert_sound: bool,
    alert_flash: bool,
    show_on_lock_screen: bool,
) -> dict[str, Any]:
    return {
        "app_name": NOTIFICATION_APP_NAME,
        "app_id": NOTIFICATION_APP_ID,
        "app_icon": NOTIFICATION_APP_ICON,
        "desktop_entry": NOTIFICATION_DESKTOP_ENTRY,
        "summary": summary,
        "body": body,
        "urgency": _notification_urgency(category_id),
        "category_hint": NOTIFICATION_CATEGORY_HINT,
        "expire_timeout_ms": 10_000,
        "alert_sound": alert_sound,
        "alert_flash": alert_flash,
        "show_on_lock_screen": show_on_lock_screen,
        "delivery_ready_claim": False,
    }


def capability_payload() -> dict[str, Any]:
    capture = _capture_bin()
    return {
        "ready": False,
        "component": "/usr/libexec/goblins-os/goblins-os-sound-listener",
        "detail": DETAIL,
        "inference_dependency": {
            "onnxruntime": _module_present("onnxruntime"),
            "numpy": _module_present("numpy"),
        },
        "model": _first_model(_model_dir()),
        "capture_driver": shutil.which(capture),
        "capture_driver_name": capture,
        "capture_runtime_ready": False,
        "capture_detail": (
            "Capture driver presence is reported, but live microphone capture "
            "has not been proven in this session."
        ),
        "decision_contract_ready": True,
        "notification_delivery_contract_ready": True,
        "runtime_ready_claim": False,
    }


def run_decision_self_test() -> None:
    assert decision_threshold("medium", 0.70) == 0.70
    assert decision_threshold("high", 0.70) == 0.60
    assert decision_threshold("low", 0.70) == 0.80
    decision = evaluate_detection_window(
        [
            {
                "audioset_class": "Vehicle horn, car horn, honking",
                "confidence": 0.99,
            },
            {"audioset_class": "Doorbell", "confidence": 0.91},
        ],
        enabled_sound_ids=["doorbell", "siren"],
        sensitivity="medium",
        min_confidence=0.70,
        now_ms=60_000,
        alert_sound=True,
        alert_flash=True,
        notify_in_lock_screen=True,
    )
    alert = decision["alert"]
    assert alert is not None
    assert alert["category_id"] == "doorbell"
    assert alert["alert_sound"] is True
    assert alert["alert_flash"] is True
    assert "Do not rely on it in emergencies" in alert["notification_body"]
    delivery_plan = alert["delivery_plan"]
    assert delivery_plan["app_id"] == NOTIFICATION_APP_ID
    assert delivery_plan["app_icon"] == NOTIFICATION_APP_ICON
    assert delivery_plan["desktop_entry"] == NOTIFICATION_DESKTOP_ENTRY
    assert delivery_plan["summary"] == alert["notification_title"]
    assert delivery_plan["body"] == alert["notification_body"]
    assert delivery_plan["urgency"] == "normal"
    assert delivery_plan["category_hint"] == NOTIFICATION_CATEGORY_HINT
    assert delivery_plan["expire_timeout_ms"] == 10_000
    assert delivery_plan["alert_sound"] is True
    assert delivery_plan["alert_flash"] is True
    assert delivery_plan["show_on_lock_screen"] is True
    assert delivery_plan["delivery_ready_claim"] is False

    safety = evaluate_detection_window(
        [{"audioset_class": "Siren", "confidence": 0.97}],
        enabled_sound_ids=["siren"],
        sensitivity="medium",
        min_confidence=0.70,
        now_ms=60_000,
    )
    assert safety["alert"] is not None
    assert safety["alert"]["delivery_plan"]["urgency"] == "critical"
    assert safety["alert"]["delivery_plan"]["delivery_ready_claim"] is False

    suppressed = evaluate_detection_window(
        [{"audioset_class": "Baby cry, infant cry", "confidence": 0.96}],
        enabled_sound_ids=["baby-crying"],
        sensitivity="medium",
        min_confidence=0.70,
        now_ms=60_000,
        last_alerts={"baby-crying": 45_000},
    )
    assert suppressed == {"alert": None, "suppressed_reason": "debounced"}


def run_self_test() -> None:
    payload = capability_payload()
    assert payload["ready"] is False
    assert payload["runtime_ready_claim"] is False
    assert payload["decision_contract_ready"] is True
    assert payload["notification_delivery_contract_ready"] is True
    assert "No microphone audio is captured" in payload["detail"]
    assert payload["capture_driver_name"]
    assert payload["component"].endswith("goblins-os-sound-listener")
    run_decision_self_test()


def run_notification_self_test() -> None:
    decision = evaluate_detection_window(
        [{"audioset_class": "Fire alarm", "confidence": 0.94}],
        enabled_sound_ids=["smoke-fire-alarm"],
        sensitivity="medium",
        min_confidence=0.70,
        now_ms=90_000,
        alert_sound=True,
        alert_flash=True,
        notify_in_lock_screen=False,
    )
    alert = decision["alert"]
    assert alert is not None
    delivery_plan = alert["delivery_plan"]
    assert delivery_plan["app_name"] == NOTIFICATION_APP_NAME
    assert delivery_plan["app_id"] == NOTIFICATION_APP_ID
    assert delivery_plan["desktop_entry"] == NOTIFICATION_DESKTOP_ENTRY
    assert delivery_plan["urgency"] == "critical"
    assert delivery_plan["show_on_lock_screen"] is False
    assert delivery_plan["delivery_ready_claim"] is False


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Goblins OS Sound Recognition listener boundary"
    )
    parser.add_argument("--capability-check", action="store_true")
    parser.add_argument("--decision-self-test", action="store_true")
    parser.add_argument("--notification-self-test", action="store_true")
    parser.add_argument("--self-test", action="store_true")
    args = parser.parse_args()

    if args.decision_self_test:
        run_decision_self_test()
        print("goblins_sound_listener_decision_selftest ok")
        return 0

    if args.notification_self_test:
        run_notification_self_test()
        print("goblins_sound_listener_notification_selftest ok")
        return 0

    if args.self_test:
        run_self_test()
        print("goblins_sound_listener_selftest ok")
        return 0

    payload = capability_payload()
    if args.capability_check:
        print(json.dumps(payload, sort_keys=True))
        return 0

    print(payload["detail"])
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
