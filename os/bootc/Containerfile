FROM docker.io/library/rust:1.88 AS rust-build

WORKDIR /src
RUN case "$(uname -m)" in \
      x86_64|aarch64) ;; \
      *) echo "Goblins OS native builds support only x86_64 and aarch64; got $(uname -m)" >&2; exit 1 ;; \
    esac \
    && rustc -Vv | grep -Eq '^host: (x86_64|aarch64)-'
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      libgtk-4-dev \
      pkg-config \
      sox \
      libsox-fmt-all \
    && rm -rf /var/lib/apt/lists/*
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
RUN cargo build --release --workspace --features "goblins-os-installer/native-desktop goblins-os-login/native-desktop goblins-os-settings/native-desktop goblins-os-shell/native-desktop goblins-os-launcher/native-desktop goblins-os-control-center/native-desktop goblins-os-markup/native-desktop goblins-os-ui/native-desktop goblins-os-visual-lookup/native-desktop goblins-os-today/native-desktop"
RUN install -d /tmp/goblins-sounds/GoblinsOS/stereo \
    && sox -n -r 48000 -c 2 /tmp/goblins-sounds/GoblinsOS/stereo/system-ready.wav synth 0.32 sine 329.63 sine 493.88 fade t 0.02 0.32 0.12 gain -18 \
    && sox -n -r 48000 -c 2 /tmp/goblins-sounds/GoblinsOS/stereo/desktop-login.wav synth 0.28 sine 392 sine 587.33 fade t 0.02 0.28 0.10 gain -19 \
    && sox -n -r 48000 -c 2 /tmp/goblins-sounds/GoblinsOS/stereo/message-new-instant.wav synth 0.16 sine 659.25 fade t 0.01 0.16 0.06 gain -22 \
    && sox -n -r 48000 -c 2 /tmp/goblins-sounds/GoblinsOS/stereo/dialog-error.wav synth 0.18 sine 220 sine 196 fade t 0.01 0.18 0.07 gain -23 \
    && sox -n -r 48000 -c 2 /tmp/goblins-sounds/GoblinsOS/stereo/screen-capture.wav synth 0.11 sine 880 fade t 0.005 0.11 0.04 gain -24

FROM quay.io/fedora/fedora-bootc:44 AS goblins-os

LABEL org.goblins-os.supported-architectures="x86_64,aarch64"

RUN image_arch="$(rpm --eval '%{_arch}')" \
    && machine_arch="$(uname -m)" \
    && case "${machine_arch}" in \
      x86_64|aarch64) ;; \
      *) echo "Goblins OS native images support only x86_64 and aarch64; got ${machine_arch}" >&2; exit 1 ;; \
    esac \
    && case "${image_arch}" in \
      x86_64|aarch64) ;; \
      *) echo "Fedora RPM architecture must be x86_64 or aarch64; got ${image_arch}" >&2; exit 1 ;; \
    esac \
    && test "${machine_arch}" = "${image_arch}"

RUN kernel_release="$(rpm -q --qf '%{VERSION}-%{RELEASE}.%{ARCH}' kernel-core)" \
