def _key_protocol_event(character: str) -> dict[str, Any]:
    return {
        "type": "key",
        "keyval": ord(character),
        "unicode": character,
        "pressed": True,
        "command_modifier_active": False,
    }


def _special_key_protocol_event(keyval: int) -> dict[str, Any]:
    return {
        "type": "key",
        "keyval": keyval,
        "unicode": None,
        "pressed": True,
        "command_modifier_active": False,
    }


