            assert target.calls == [("update", "on my way", 9, True)]
            assert response.get("candidate", {}).get("replacement") == "on my way"
            assert response.get("candidate", {}).get("rendered_bubble_ready_claim") is False
            assert candidate_state.current is not None
            assert candidate_state.last_overlay_intent is not None
            assert candidate_state.last_overlay_intent["action"] == "show-candidate"
            assert candidate_state.last_overlay_intent["live_overlay_claim"] is False
            response = runtime.send(_key_protocol_event(" "))
            assert response.get("handled") is True
            _apply_response_operations(target, response, lambda text: text, candidate_state)
            assert target.calls == [
                ("update", "on my way", 9, True),
                ("delete", -3, 3),
                ("commit", "on my way "),
                ("hide",),
            ]
            assert candidate_state.current is None
            assert candidate_state.last_overlay_intent == {
                "action": "hide-candidate",
                "replacement": "on my way",
                "accept_on": "word-boundary",
                "dismiss_key": "Escape",
