# Product identity: this is Goblins OS, not Fedora. Rebrand os-release (NAME /
# PRETTY_NAME / VARIANT) while keeping ID=fedora + the version intact so dnf and
# bootc still resolve the platform correctly.
RUN sed -i \
      -e 's/^NAME=.*/NAME="Goblins OS"/' \
      -e 's/^PRETTY_NAME=.*/PRETTY_NAME="Goblins OS"/' \
      -e '/^VARIANT=/d' -e '/^VARIANT_ID=/d' \
      /usr/lib/os-release \
    && printf 'VARIANT="Goblins OS"\nVARIANT_ID=goblins-os\n' >> /usr/lib/os-release

# Boot identity: the Goblins OS Plymouth splash replaces Fedora's. The mark is
# the shipped Goblins mark; setting the default theme writes plymouthd.conf (the
# initramfs regen happens at deploy).
RUN cp /usr/share/goblins-os/brand/anaconda/sidebar-logo.png \
        /usr/share/plymouth/themes/goblins-os/logo.png \
    && plymouth-set-default-theme goblins-os

# Themed GNOME stock utilities: GoblinsOS icon theme ships source-owned graphite
# tiles and a one-weight symbolic family, inheriting Adwaita for everything else.
RUN (gtk4-update-icon-cache -f /usr/share/icons/GoblinsOS \
        || gtk-update-icon-cache -f /usr/share/icons/GoblinsOS || true)

# Shell-extension keybindings live in the extension's GSettings schema so Mutter
# owns the shortcuts directly.
RUN glib-compile-schemas /usr/share/gnome-shell/extensions/goblins-wm@goblins.os/schemas

# Goblins-owned system schemas (Focus modes, …) compiled into the shared schema set.
RUN glib-compile-schemas /usr/share/glib-2.0/schemas

# Rebrand the Anaconda installer chrome (the disk installer the ISO boots into):
# recolor the Fedora-blue sidebar base (#51a2da) to Goblins ink so the sidebar
# reads dark and on-brand; the dark sidebar art + white mark are COPYed above.
RUN sed -i 's/#51a2da/#0b0b0f/g' /usr/share/anaconda/pixmaps/fedora.css 2>/dev/null || true

RUN chmod 0755 /usr/libexec/goblins-os/goblins-os-session \
    && test -x /usr/libexec/goblins-os/goblins-os-firewall \
    && test -f /usr/lib/systemd/system/goblins-os-firewall@.service \
    && test -f /etc/polkit-1/rules.d/60-goblins-os-firewall.rules \
    && grep -Fq 'unit.match(/^goblins-os-firewall@(enable|disable)\.service$/)' /etc/polkit-1/rules.d/60-goblins-os-firewall.rules \
    && install -d -o goblin -g goblin /var/home/goblin/.local/share/nautilus/scripts \
    && install -m 0755 "/usr/share/goblins-os/nautilus/scripts/Build an app to open this" "/var/home/goblin/.local/share/nautilus/scripts/Build an app to open this" \
    && install -m 0755 "/usr/share/goblins-os/nautilus/scripts/Ask Goblin about this" "/var/home/goblin/.local/share/nautilus/scripts/Ask Goblin about this" \
    && chown -R goblin:goblin /var/home/goblin/.local/share/nautilus \
    && chown root:root /etc/goblins-os/openai-secrets.env \
    && chmod 0600 /etc/goblins-os/openai-secrets.env \
    && test "$(stat -c '%U:%G:%a' /etc/goblins-os/openai-secrets.env)" = "root:root:600" \
    && ! grep -Eq '^[[:space:]]*[A-Za-z0-9_]*(KEY|SECRET|TOKEN)[[:space:]]*=' /etc/goblins-os/openai-secrets.env \
    && ! grep -Eq '^[[:space:]]*[A-Za-z0-9_]*(KEY|SECRET|TOKEN)[[:space:]]*=' /etc/goblins-os/environment \
    && printf '%s\n' \
        'GTK_IM_MODULE=gtk-im-context-simple' \
        'QT_IM_MODULE=simple' \
        'XMODIFIERS=@im=none' \
        'IBUS_ENABLE_SYNC_MODE=0' \
        > /var/home/goblin/.config/environment.d/10-goblins-os-input.conf \
    && chown goblin:goblin /var/home/goblin/.config/environment.d/10-goblins-os-input.conf \
    && touch /var/lib/goblins-os/.config/gnome-initial-setup-done \
    && chown -R goblins-os:goblins-os /var/lib/goblins-os/.local /var/lib/goblins-os/.config /var/lib/goblins-os/installer /var/lib/goblins-os/session /var/lib/goblins-os/policy \
    && dconf update \
    && systemctl enable NetworkManager.service \
    && systemctl enable firewalld.service \
    && systemctl enable gdm.service \
    && systemctl enable goblins-os-model-cache.service \
    && systemctl enable goblins-os-core.service \
    && systemctl enable goblins-os-resident.service \
    && bootc container lint
