# Goblins OS — non-secret system configuration, shared by the OS services and the
# desktop session. Every value here is safe to expose: ports, loopback URLs,
# on-disk paths, and modes. This file is world-readable and is sourced into the
# GUI session, so it MUST NEVER hold credentials (OAuth client secrets, API keys,
# relay tokens). Operator secrets belong only in /etc/goblins-os/openai-secrets.env
# (mode 0600 root:root, loaded by systemd before services drop privileges, never the session) or a
# per-service systemd drop-in. See that file for the provisioning template.
GOBLINS_OS_CORE_PORT=8787
GOBLINS_OS_CORE_URL=http://127.0.0.1:8787
# Older external launchers can still pass legacy core aliases into the service
# binaries, but the shipping image and GUI session publish only Goblins-native
# names.
GOBLINS_OS_BOOTC_IMAGE=localhost/goblins-os:dev
GOBLINS_OS_SESSION=gnome-native-desktop
GOBLINS_OS_GUI_PLATFORM=gnome-session
GOBLINS_OS_SHELL_MODE=native-desktop
GOBLINS_OS_MODEL_DIR=/var/lib/goblins-os/models
GOBLINS_OS_MODEL_INSTALL_STATE=/var/lib/goblins-os/models/install-state
GOBLINS_OS_MODEL_MANIFEST_DIR=/etc/goblins-os/model-manifests
GOBLINS_OS_INSTALLER_STATE=/var/lib/goblins-os/installer
GOBLINS_OS_SESSION_STATE=/var/lib/goblins-os/session
GOBLINS_OS_SESSION_BRIDGE_SOCKET=/run/goblins-os-session/session-bridge.sock
GOBLINS_OS_POLICY_STATE=/var/lib/goblins-os/policy
GOBLINS_OS_RESIDENT_STATE=/var/lib/goblins-os/resident
GOBLINS_OS_RESIDENT_SOCKET=/run/goblins-os/resident.sock
# Codex CLI (the user's OpenAI account). Owned by the goblins-os service user and
# locked 0700: only the core service reads or writes it. The desktop session is
# NOT in the goblins-os group, so it cannot read auth.json — sign-in (browser
# OAuth) is driven by the core, which opens the URL through the session. The path
# itself is not a secret (so it is safe to publish here); its contents are.
CODEX_HOME=/var/lib/goblins-os/codex
GOBLINS_OS_VOICE_DIR=/var/lib/goblins-os/voice
GOBLINS_OS_POLICY_PROFILE=consumer
GOBLINS_OS_SHELL_CORE_WAIT_SECS=60
GOBLINS_OS_INSTALLER_CORE_WAIT_SECS=60
GOBLINS_OS_LOGIN_CORE_WAIT_SECS=60
GOBLINS_OS_OPEN_CORE_WAIT_SECS=60
GOBLINS_OS_SETTINGS_CORE_WAIT_SECS=60
