def _run_overlay_intent_self_test() -> dict[str, Any]:
    class FakeTarget:
        def __init__(self) -> None:
            self.calls: list[tuple[Any, ...]] = []

        def update_preedit_text(self, text: str, cursor_pos: int, visible: bool) -> None:
            self.calls.append(("update", text, cursor_pos, visible))

        def hide_preedit_text(self) -> None:
            self.calls.append(("hide",))

        def delete_surrounding_text(self, offset: int, n_chars: int) -> None:
            self.calls.append(("delete", offset, n_chars))

        def commit_text(self, text: str) -> None:
            self.calls.append(("commit", text))

    intents: list[dict[str, Any]] = []
    with tempfile.TemporaryDirectory() as tmpdir:
        table_path = os.path.join(tmpdir, "text-shortcuts.json")
        with open(table_path, "w", encoding="utf-8") as table_file:
            json.dump([{"replace": "omw", "with": "on my way"}], table_file)

        target = FakeTarget()
        candidate_state = CandidateMetadataState()
        table_bridge = ShortcutTableBridge(table_path)
        runtime = RuntimeBridge(response_timeout=CAPABILITY_TIMEOUT_SECONDS)
        try:
            _send_table_changed_if_needed(
                table_bridge,
                runtime,
                target,
                lambda text: text,
                candidate_state,
            )
            for character in "omw":
                response = runtime.send(_key_protocol_event(character))
                _apply_response_operations(
                    target,
                    response,
                    lambda text: text,
                    candidate_state,
                )
            intents.append(
                _assert_overlay_intent(
                    candidate_state.last_overlay_intent,
                    "show-candidate",
                    "candidate-visible",
                )
            )
            response = runtime.send(_special_key_protocol_event(0xFF1B))
            _apply_response_operations(target, response, lambda text: text, candidate_state)
            intents.append(
                _assert_overlay_intent(
                    candidate_state.last_overlay_intent,
                    "hide-candidate",
                    "dismissed",
                )
            )

            target.calls.clear()
            for character in "omw":
                response = runtime.send(_key_protocol_event(character))
                _apply_response_operations(
                    target,
                    response,
                    lambda text: text,
                    candidate_state,
                )
            intents.append(
                _assert_overlay_intent(
                    candidate_state.last_overlay_intent,
                    "show-candidate",
                    "candidate-visible",
                )
            )
            response = runtime.send(_key_protocol_event(" "))
            _apply_response_operations(target, response, lambda text: text, candidate_state)
            intents.append(
                _assert_overlay_intent(
                    candidate_state.last_overlay_intent,
                    "hide-candidate",
                    "committed",
                )
            )

            runtime.send({"type": "focus-in", "purpose": 9})
            target.calls.clear()
            for character in "omw ":
                response = runtime.send(_key_protocol_event(character))
                _apply_response_operations(target, response, lambda text: text, candidate_state)
            assert target.calls == []
            assert candidate_state.current is None
        finally:
            runtime.close()

    payload = _overlay_intent_proof_payload(intents)
    assert payload["show_count"] == 2
    assert payload["hide_count"] == 2
    return payload


