def _run_candidate_bubble_render_intent_self_test() -> dict[str, Any]:
    class FakeTarget:
        def __init__(self) -> None:
            self.calls: list[tuple[Any, ...]] = []

        def update_preedit_text(self, text: str, cursor_pos: int, visible: bool) -> None:
            self.calls.append(("update", text, cursor_pos, visible))

        def hide_preedit_text(self) -> None:
            self.calls.append(("hide",))

        def delete_surrounding_text(self, offset: int, n_chars: int) -> None:
            self.calls.append(("delete", offset, n_chars))

        def commit_text(self, text: str) -> None:
            self.calls.append(("commit", text))

    class FailingSink(CandidateBubbleRenderIntentSink):
        def publish(self, intent: dict[str, Any]) -> None:
            del intent
            raise RuntimeError("sink unavailable")

    def apply_response(
        target: FakeTarget,
        response: dict[str, Any],
        state: CandidateMetadataState,
        controller: CandidateBubbleRenderIntentController,
    ) -> None:
        _apply_response_operations_with_render_intent(
            target,
            response,
            lambda text: text,
            state,
            controller,
        )

    def type_candidate(
        runtime: RuntimeBridge,
        target: FakeTarget,
        state: CandidateMetadataState,
        controller: CandidateBubbleRenderIntentController,
    ) -> None:
        for character in "omw":
            apply_response(
                target,
                runtime.send(_key_protocol_event(character)),
                state,
                controller,
            )
        assert state.current is not None
        assert state.last_overlay_intent is not None
        assert state.last_overlay_intent["action"] == "show-candidate"

    sink = RecordingCandidateBubbleRenderIntentSink()
    controller = CandidateBubbleRenderIntentController(
        sink=sink,
        anchor_provider=lambda: _rect(120, 140, 1, 22),
        monitor_provider=lambda: _rect(0, 0, 800, 600),
    )

    with tempfile.TemporaryDirectory() as tmpdir:
        table_path = os.path.join(tmpdir, "text-shortcuts.json")
        with open(table_path, "w", encoding="utf-8") as table_file:
            json.dump([{"replace": "omw", "with": "on my way"}], table_file)
        os.chmod(table_path, 0o600)

        target = FakeTarget()
        candidate_state = CandidateMetadataState()
        table_bridge = ShortcutTableBridge(table_path)
        runtime = RuntimeBridge(response_timeout=CAPABILITY_TIMEOUT_SECONDS)
        try:
            _send_table_changed_if_needed(
                table_bridge,
                runtime,
                target,
                lambda text: text,
                candidate_state,
                controller,
            )

            type_candidate(runtime, target, candidate_state, controller)
            assert target.calls == []
            before_key_release = len(sink.records)
            release_response = runtime.send(
                {
                    "type": "key",
                    "keyval": ord("w"),
                    "unicode": None,
                    "pressed": False,
                    "command_modifier_active": False,
                }
            )
            assert release_response.get("handled") is False
            apply_response(
                target,
                release_response,
                candidate_state,
                controller,
            )
            key_release_preserved_candidate = (
                candidate_state.current is not None
                and len(sink.records) == before_key_release
                and target.calls == []
            )
            apply_response(
                target,
                runtime.send(_special_key_protocol_event(0xFF1B)),
                candidate_state,
                controller,
            )
            assert sink.records[-1]["action"] == "hide-candidate"
            assert sink.records[-1]["reason"] == "dismissed"

            target.calls.clear()
            type_candidate(runtime, target, candidate_state, controller)
            apply_response(
                target,
                runtime.send(_key_protocol_event(" ")),
                candidate_state,
                controller,
            )
            assert target.calls == [
                ("delete", -3, 3),
                ("commit", "on my way "),
                ("hide",),
            ]
            assert sink.records[-1]["action"] == "hide-candidate"
            assert sink.records[-1]["reason"] == "committed"

            target.calls.clear()
            type_candidate(runtime, target, candidate_state, controller)
            before_focus_out = len(sink.records)
            apply_response(
                target,
                runtime.send({"type": "focus-out"}),
                candidate_state,
                controller,
            )
            focus_out_hide = (
                len(sink.records) == before_focus_out + 1
                and sink.records[-1]["action"] == "hide-candidate"
            )

            apply_response(
                target,
                runtime.send(_content_purpose_request("focus-in", 0)),
                candidate_state,
                controller,
            )
            target.calls.clear()
            type_candidate(runtime, target, candidate_state, controller)
            before_sensitive = len(sink.records)
            apply_response(
                target,
                runtime.send(_content_purpose_request("content-purpose-changed", 9)),
                candidate_state,
                controller,
            )
            sensitive_hide = (
                len(sink.records) == before_sensitive + 1
                and sink.records[-1]["action"] == "hide-candidate"
            )

            target.calls.clear()
            before_passthrough = len(sink.records)
            for character in "omw ":
                response = runtime.send(_key_protocol_event(character))
                assert response.get("handled") is False
                apply_response(target, response, candidate_state, controller)
            pass_through_unchanged = (
                len(sink.records) == before_passthrough and target.calls == []
            )
        finally:
            runtime.close()

    failing_target = FakeTarget()
    failing_state = CandidateMetadataState()
    failing_controller = CandidateBubbleRenderIntentController(
        sink=FailingSink(),
        anchor_provider=lambda: _rect(120, 140, 1, 22),
        monitor_provider=lambda: _rect(0, 0, 800, 600),
    )
    failing_publication_applied = _apply_response_operations_with_render_intent(
        failing_target,
        {
            "handled": False,
            "operations": [],
            "candidate": {
                "trigger": "omw",
                "replacement": "on my way",
                "accept_on": "word-boundary",
                "dismiss_key": "Escape",
                "rendered_bubble_ready_claim": False,
            },
        },
        lambda text: text,
        failing_state,
        failing_controller,
    )
    sink_failure_fail_open = (
        failing_publication_applied is False
        and failing_target.calls == []
    )

    runtime_failure_target = FakeTarget()
    runtime_failure_state = CandidateMetadataState()
    runtime_failure_sink = RecordingCandidateBubbleRenderIntentSink()
    runtime_failure_controller = CandidateBubbleRenderIntentController(
        sink=runtime_failure_sink,
        anchor_provider=lambda: _rect(120, 140, 1, 22),
        monitor_provider=lambda: _rect(0, 0, 800, 600),
    )
    apply_response(
        runtime_failure_target,
        {
            "handled": False,
            "operations": [],
            "candidate": {
                "trigger": "omw",
                "replacement": "on my way",
                "accept_on": "word-boundary",
                "dismiss_key": "Escape",
                "rendered_bubble_ready_claim": False,
            },
        },
        runtime_failure_state,
        runtime_failure_controller,
    )
    apply_response(
        runtime_failure_target,
        _passthrough_response(),
        runtime_failure_state,
        runtime_failure_controller,
    )
    runtime_failure_cleanup = (
        runtime_failure_target.calls == [("hide",)]
        and runtime_failure_state.current is None
        and runtime_failure_sink.records[-1]["action"] == "hide-candidate"
        and runtime_failure_sink.records[-1]["reason"] == "runtime-unavailable"
    )

    show_count = sum(
        1 for intent in sink.records if intent.get("action") == "show-candidate"
    )
    hide_count = sum(
        1 for intent in sink.records if intent.get("action") == "hide-candidate"
    )
    payload = {
        "status": "pass",
        "surface": ACCEPT_BUBBLE_RENDER_INTENT_SURFACE,
        "frame_surface": ACCEPT_BUBBLE_FRAME_SURFACE,
        "layout_surface": ACCEPT_BUBBLE_LAYOUT_SURFACE,
        "render_intents": sink.records,
        "render_intent_count": len(sink.records),
        "show_intent_count": show_count,
        "hide_intent_count": hide_count,
        "dismissed_intent": any(
            intent.get("reason") == "dismissed" for intent in sink.records
        ),
        "committed_intent": any(
            intent.get("reason") == "committed" for intent in sink.records
        ),
        "focus_out_hide": focus_out_hide,
        "sensitive_hide": sensitive_hide,
        "pass_through_unchanged": pass_through_unchanged,
        "key_release_preserved_candidate": key_release_preserved_candidate,
        "runtime_failure_cleanup": runtime_failure_cleanup,
        "sink_failure_fail_open": sink_failure_fail_open,
        "style_class": ACCEPT_BUBBLE_STYLE_CLASS,
        "font_family": "Inter",
        "rendered_bubble_ready_claim": False,
        "live_overlay_claim": False,
        "runtime_ready_claim": False,
    }
    assert payload["render_intent_count"] == 8
    assert payload["show_intent_count"] == 4
    assert payload["hide_intent_count"] == 4
    assert payload["dismissed_intent"] is True
    assert payload["committed_intent"] is True
    assert payload["focus_out_hide"] is True
    assert payload["sensitive_hide"] is True
    assert payload["pass_through_unchanged"] is True
    assert payload["key_release_preserved_candidate"] is True
    assert payload["runtime_failure_cleanup"] is True
    assert payload["sink_failure_fail_open"] is True
    assert all(intent["has_layout"] is True for intent in sink.records)
    assert payload["rendered_bubble_ready_claim"] is False
    assert payload["live_overlay_claim"] is False
    assert payload["runtime_ready_claim"] is False
    return payload


