def _bounded_utf8_text(
    value: Any,
    *,
    allow_empty: bool,
    max_characters: int,
    max_bytes: int,
) -> bool:
    if not isinstance(value, str) or (not allow_empty and not value):
        return False
    if len(value) > max_characters or "\x00" in value:
        return False
    try:
        encoded = value.encode("utf-8", errors="strict")
    except UnicodeEncodeError:
        return False
    return len(encoded) <= max_bytes


def _runtime_text_is_safe(value: Any, *, allow_empty: bool = False) -> bool:
    return _bounded_utf8_text(
        value,
        allow_empty=allow_empty,
        max_characters=RUNTIME_TEXT_MAX_CHARACTERS,
        max_bytes=RUNTIME_TEXT_MAX_BYTES,
    )


def _runtime_binary() -> str:
    return os.environ.get("GOBLINS_TEXTSHORTCUTS_ENGINE", RUNTIME_PATH)


def _runtime_argv() -> list[str]:
    return [_runtime_binary(), "--stdio"]


def _runtime_stdio_self_test(argv: list[str] | None = None) -> bool:
    command = argv or [_runtime_binary(), "--stdio-self-test"]
    try:
        result = subprocess.run(
            command,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            encoding="utf-8",
            timeout=CAPABILITY_TIMEOUT_SECONDS,
        )
    except (OSError, subprocess.TimeoutExpired):
        return False
    return (
        result.returncode == 0
        and "goblins_textshortcuts_stdio_selftest ok" in result.stdout
    )


def capability_payload(runtime_self_test_argv: list[str] | None = None) -> dict[str, Any]:
    adapter_contract_ready = _runtime_stdio_self_test(runtime_self_test_argv)
    detail = (
        "Text Shortcuts IBus adapter is installed and the Rust stdio contract "
        "self-test passes; live IBus expansion still requires CI/qemu proof."
        if adapter_contract_ready
        else "Text Shortcuts IBus adapter is installed, but the Rust stdio "
        "contract self-test is not available in this session."
    )
    return {
        "ready": False,
        "adapter_contract_ready": adapter_contract_ready,
        "component": ADAPTER_PATH,
        "engine_name": ENGINE_NAME,
        "runtime": _runtime_binary(),
        "runtime_ready_claim": False,
        "detail": detail,
    }


def _table_path() -> str | None:
    config_home = os.environ.get("XDG_CONFIG_HOME")
    if config_home and not os.path.isabs(config_home):
        return None
    if not config_home:
        home = os.environ.get("HOME")
        if not home or not os.path.isabs(home):
            return None
        config_home = os.path.join(home, ".config")
    if not config_home:
        return None
    return os.path.join(
        config_home,
        TEXT_SHORTCUTS_CONFIG_DIR,
        TEXT_SHORTCUTS_CONFIG_FILE,
    )


def _sanitize_shortcuts(raw: Any) -> list[dict[str, str]]:
    if not isinstance(raw, list):
        return []
    order: list[str] = []
    replacements: dict[str, str] = {}
    for entry in raw:
        if not isinstance(entry, dict):
            return []
        replace_value = entry.get("replace")
        with_value = entry.get("with")
        if not isinstance(replace_value, str) or not isinstance(with_value, str):
            return []
        if not _runtime_text_is_safe(replace_value) or not _runtime_text_is_safe(
            with_value
        ):
            continue
        replace = replace_value.strip()
        with_text = with_value.strip()
        if not replace or not with_text or replace == with_text:
            continue
        if replace not in replacements:
            order.append(replace)
        replacements[replace] = with_text
    return [
        {"replace": replace, "with": replacements[replace]}
        for replace in order[:MAX_SHORTCUTS]
    ]


def _table_snapshot(path: str | None = None) -> tuple[str, list[dict[str, str]]]:
    table_path = path or _table_path()
    if table_path is None:
        return ("no-config-home", [])
    try:
        descriptor = os.open(
            table_path,
            os.O_RDONLY
            | getattr(os, "O_CLOEXEC", 0)
            | getattr(os, "O_NOFOLLOW", 0),
        )
    except FileNotFoundError:
        return ("missing", [])
    except OSError:
        return ("unreadable", [])
    try:
        metadata = os.fstat(descriptor)
        if (
            not stat.S_ISREG(metadata.st_mode)
            or metadata.st_uid != os.geteuid()
            or stat.S_IMODE(metadata.st_mode) != 0o600
        ):
            return ("unsafe-file", [])
        chunks: list[bytes] = []
        remaining = MAX_TEXT_SHORTCUTS_TABLE_BYTES + 1
        while remaining > 0:
            chunk = os.read(descriptor, remaining)
            if not chunk:
                break
            chunks.append(chunk)
            remaining -= len(chunk)
        raw_bytes = b"".join(chunks)
    except OSError:
        return ("unreadable", [])
    finally:
        os.close(descriptor)
    if len(raw_bytes) > MAX_TEXT_SHORTCUTS_TABLE_BYTES:
        return ("too-large", [])
    if not raw_bytes:
        return ("empty", [])
    fingerprint = hashlib.sha256(raw_bytes).hexdigest()
    try:
        raw_shortcuts = json.loads(raw_bytes.decode("utf-8"))
    except (UnicodeDecodeError, ValueError, json.JSONDecodeError):
        return (fingerprint, [])
    return (fingerprint, _sanitize_shortcuts(raw_shortcuts))


class ShortcutTableBridge:
    def __init__(self, path: str | None = None) -> None:
        self._path = path
        self._fingerprint: str | None = None

    def invalidate(self) -> None:
        self._fingerprint = None

    def maybe_changed_request(self) -> dict[str, Any] | None:
        fingerprint, shortcuts = _table_snapshot(self._path)
        if fingerprint == self._fingerprint:
            return None
        self._fingerprint = fingerprint
        return {"type": "table-changed", "shortcuts": shortcuts}


def _candidate_metadata_from_response(response: dict[str, Any]) -> dict[str, Any] | None:
    candidate = response.get("candidate")
    if not isinstance(candidate, dict):
        return None
    trigger = candidate.get("trigger")
    replacement = candidate.get("replacement")
    accept_on = candidate.get("accept_on")
    dismiss_key = candidate.get("dismiss_key")
    rendered_bubble_ready_claim = candidate.get("rendered_bubble_ready_claim")
    if (
        not isinstance(trigger, str)
        or not trigger
        or not isinstance(replacement, str)
        or not replacement
        or not isinstance(accept_on, str)
        or accept_on != "word-boundary"
        or not isinstance(dismiss_key, str)
        or dismiss_key != "Escape"
        or rendered_bubble_ready_claim is not False
    ):
        return None
    return {
        "replacement": replacement,
        "accept_on": accept_on,
        "dismiss_key": dismiss_key,
        "rendered_bubble_ready_claim": False,
    }


def _candidate_clear_reason(response: dict[str, Any]) -> str:
    operations = response.get("operations", [])
    if not isinstance(operations, list):
        return "cleared"
    operation_types = {
        operation.get("type")
        for operation in operations
        if isinstance(operation, dict) and isinstance(operation.get("type"), str)
    }
    if "commit-text" in operation_types:
        return "committed"
    if "hide-preedit-text" in operation_types and response.get("handled") is True:
        return "dismissed"
    if "hide-preedit-text" in operation_types:
        return "hidden"
    return "cleared"


def _candidate_overlay_intent(
    action: str,
    metadata: dict[str, Any],
    reason: str,
) -> dict[str, Any]:
    return {
        "action": action,
        "replacement": metadata["replacement"],
        "accept_on": metadata["accept_on"],
        "dismiss_key": metadata["dismiss_key"],
        "reason": reason,
        "rendered_bubble_ready_claim": False,
        "live_overlay_claim": False,
        "runtime_ready_claim": False,
    }


def _candidate_bubble_frame_from_intent(intent: dict[str, Any]) -> dict[str, Any] | None:
    action = intent.get("action")
    replacement = intent.get("replacement")
    accept_on = intent.get("accept_on")
    dismiss_key = intent.get("dismiss_key")
    reason = intent.get("reason")
    if (
        action not in {"show-candidate", "hide-candidate"}
        or not isinstance(replacement, str)
        or not replacement
        or accept_on != "word-boundary"
        or dismiss_key != "Escape"
        or not isinstance(reason, str)
        or intent.get("rendered_bubble_ready_claim") is not False
        or intent.get("live_overlay_claim") is not False
        or intent.get("runtime_ready_claim") is not False
    ):
        return None
    return {
        "surface": ACCEPT_BUBBLE_FRAME_SURFACE,
        "action": action,
        "replacement": replacement,
        "accept_on": accept_on,
        "accept_keys": ["Space", "Return"],
        "dismiss_key": dismiss_key,
        "reason": reason,
        "style_class": ACCEPT_BUBBLE_STYLE_CLASS,
        "text_style_class": ACCEPT_BUBBLE_TEXT_STYLE_CLASS,
        "hint_style_class": ACCEPT_BUBBLE_HINT_STYLE_CLASS,
        "font_family": "Inter",
        "rendered_bubble_ready_claim": False,
        "live_overlay_claim": False,
        "runtime_ready_claim": False,
    }


def _candidate_bubble_frames_from_overlay_intents(
    intents: list[dict[str, Any]],
) -> list[dict[str, Any]]:
    frames: list[dict[str, Any]] = []
    for intent in intents:
        frame = _candidate_bubble_frame_from_intent(intent)
        assert frame is not None
        frames.append(frame)
    return frames


def _rect(x: int, y: int, width: int, height: int) -> dict[str, int]:
    return {
        "x": int(x),
        "y": int(y),
        "width": int(width),
        "height": int(height),
    }


def _normalize_rect(rect: dict[str, Any]) -> dict[str, int] | None:
    if not isinstance(rect, dict):
        return None
    try:
        normalized = _rect(
            int(rect["x"]),
            int(rect["y"]),
            int(rect["width"]),
            int(rect["height"]),
        )
    except (KeyError, TypeError, ValueError):
        return None
    if normalized["width"] <= 0 or normalized["height"] <= 0:
        return None
    return normalized


def _clamp(value: int, lower: int, upper: int) -> int:
    if upper < lower:
        return lower
    return min(max(value, lower), upper)


def _candidate_bubble_width(replacement: str) -> int:
    natural_width = (
        BUBBLE_LAYOUT_HORIZONTAL_PADDING
        + len(replacement) * BUBBLE_LAYOUT_CHARACTER_WIDTH
    )
    return _clamp(
        natural_width,
        BUBBLE_LAYOUT_MIN_WIDTH,
        BUBBLE_LAYOUT_MAX_WIDTH,
    )


def _valid_frame_contract(frame: dict[str, Any]) -> bool:
    return (
        frame.get("surface") == ACCEPT_BUBBLE_FRAME_SURFACE
        and frame.get("style_class") == ACCEPT_BUBBLE_STYLE_CLASS
        and frame.get("text_style_class") == ACCEPT_BUBBLE_TEXT_STYLE_CLASS
        and frame.get("hint_style_class") == ACCEPT_BUBBLE_HINT_STYLE_CLASS
        and frame.get("font_family") == "Inter"
        and frame.get("accept_on") == "word-boundary"
        and frame.get("dismiss_key") == "Escape"
        and frame.get("rendered_bubble_ready_claim") is False
        and frame.get("live_overlay_claim") is False
        and frame.get("runtime_ready_claim") is False
    )


def _candidate_bubble_layout_from_frame(
    frame: dict[str, Any],
    anchor_rect: dict[str, Any],
    monitor_rect: dict[str, Any],
) -> dict[str, Any] | None:
    replacement = frame.get("replacement")
    reason = frame.get("reason")
    action = frame.get("action")
    if (
        not _valid_frame_contract(frame)
        or action not in {"show-candidate", "hide-candidate"}
        or not isinstance(replacement, str)
        or not replacement
        or not isinstance(reason, str)
    ):
        return None
    base = {
        "surface": ACCEPT_BUBBLE_LAYOUT_SURFACE,
        "frame_surface": ACCEPT_BUBBLE_FRAME_SURFACE,
        "action": action,
        "replacement": replacement,
        "accept_on": "word-boundary",
        "accept_keys": ["Space", "Return"],
        "dismiss_key": "Escape",
        "reason": reason,
        "style_class": ACCEPT_BUBBLE_STYLE_CLASS,
        "text_style_class": ACCEPT_BUBBLE_TEXT_STYLE_CLASS,
        "hint_style_class": ACCEPT_BUBBLE_HINT_STYLE_CLASS,
        "font_family": "Inter",
        "rendered_bubble_ready_claim": False,
        "live_overlay_claim": False,
        "runtime_ready_claim": False,
    }
    if action == "hide-candidate":
        return {
            **base,
            "visible": False,
            "placement": "hidden",
            "anchor_rect": None,
            "monitor_rect": None,
            "bubble_rect": None,
            "clamped_x": False,
            "flipped_y": False,
        }

    anchor = _normalize_rect(anchor_rect)
    monitor = _normalize_rect(monitor_rect)
    if anchor is None or monitor is None:
        return None

    width = _candidate_bubble_width(replacement)
    height = BUBBLE_LAYOUT_HEIGHT
    minimum_x = monitor["x"] + BUBBLE_LAYOUT_MARGIN
    maximum_x = monitor["x"] + monitor["width"] - BUBBLE_LAYOUT_MARGIN - width
    preferred_x = anchor["x"]
    x = _clamp(preferred_x, minimum_x, maximum_x)

    minimum_y = monitor["y"] + BUBBLE_LAYOUT_MARGIN
    maximum_y = monitor["y"] + monitor["height"] - BUBBLE_LAYOUT_MARGIN - height
    below_y = anchor["y"] + anchor["height"] + BUBBLE_LAYOUT_GAP
    above_y = anchor["y"] - BUBBLE_LAYOUT_GAP - height
    if below_y + height <= monitor["y"] + monitor["height"] - BUBBLE_LAYOUT_MARGIN:
        y = below_y
        placement = "below-cursor"
        flipped_y = False
    elif above_y >= minimum_y:
        y = above_y
        placement = "above-cursor"
        flipped_y = True
    else:
        y = _clamp(below_y, minimum_y, maximum_y)
        placement = "within-monitor"
        flipped_y = False

    return {
        **base,
        "visible": True,
        "placement": placement,
        "anchor_rect": anchor,
        "monitor_rect": monitor,
        "bubble_rect": _rect(x, y, width, height),
        "clamped_x": x != preferred_x,
        "flipped_y": flipped_y,
        "gap": BUBBLE_LAYOUT_GAP,
        "margin": BUBBLE_LAYOUT_MARGIN,
    }


class CandidateMetadataState:
    def __init__(self) -> None:
        self.current: dict[str, Any] | None = None
        self.last_overlay_intent: dict[str, Any] | None = None

    def observe_response(self, response: dict[str, Any]) -> None:
        previous = self.current
        candidate = _candidate_metadata_from_response(response)
        if candidate is not None:
            self.current = candidate
            self.last_overlay_intent = _candidate_overlay_intent(
                "show-candidate",
                candidate,
                "candidate-visible",
            )
            return
        operations = response.get("operations", [])
        operation_types: set[str] = set()
        if isinstance(operations, list):
            operation_types = {
                operation.get("type")
                for operation in operations
                if isinstance(operation, dict)
                and isinstance(operation.get("type"), str)
            }
        runtime_unavailable = response.get("runtime_available") is False
        if previous is not None and (
            runtime_unavailable or "hide-preedit-text" in operation_types
        ):
            self.current = None
            self.last_overlay_intent = _candidate_overlay_intent(
                "hide-candidate",
                previous,
                "runtime-unavailable"
                if runtime_unavailable
                else _candidate_clear_reason(response),
            )
            return
        # Key releases and other pass-through responses intentionally omit the
        # candidate. Preserve the current native lookup table until the runtime
        # explicitly hides preedit or the bridge reports that it is unavailable.
        self.last_overlay_intent = None

    def clear(self, reason: str = "cleared") -> None:
        previous = self.current
        self.current = None
        if previous is not None:
            self.last_overlay_intent = _candidate_overlay_intent(
                "hide-candidate",
                previous,
                reason,
            )
        else:
            self.last_overlay_intent = None


class CandidateBubbleRenderIntentSink:
    def publish(self, intent: dict[str, Any]) -> bool:
        del intent
        return True


class RecordingCandidateBubbleRenderIntentSink(CandidateBubbleRenderIntentSink):
    def __init__(self) -> None:
        self.records: list[dict[str, Any]] = []

    def publish(self, intent: dict[str, Any]) -> bool:
        self.records.append(intent)
        return True


class RedactedAdapterCallbackLedger(CandidateBubbleRenderIntentSink):
    def __init__(self, path: str | None = None) -> None:
        self.path = path
        self.records: list[dict[str, Any]] = []

    def callback(self, name: str) -> None:
        self._record(
            {
                "event": "callback",
                "callback": name,
                "surface": ADAPTER_CALLBACK_LEDGER_SURFACE,
                "redacted": True,
            }
        )

    def operations(self, callback: str, response: dict[str, Any]) -> None:
        operations = response.get("operations", [])
        if not isinstance(operations, list):
            operation_types: list[str] = []
        else:
            operation_types = [
                operation["type"]
                for operation in operations
                if isinstance(operation, dict) and isinstance(operation.get("type"), str)
            ]
        self._record(
            {
                "event": "operations",
                "callback": callback,
                "operation_types": operation_types,
                "handled": bool(response.get("handled", False)),
                "candidate": _candidate_metadata_from_response(response) is not None,
                "surface": ADAPTER_CALLBACK_LEDGER_SURFACE,
                "redacted": True,
            }
        )

    def table_reload(self, shortcut_count: int) -> None:
        self._record(
            {
                "event": "table-reload",
                "callback": "table-changed",
                "shortcut_count": max(0, int(shortcut_count)),
                "surface": ADAPTER_CALLBACK_LEDGER_SURFACE,
                "redacted": True,
            }
        )

    def content_purpose(self, sensitive_purpose: bool) -> None:
        self._record(
            {
                "event": "content-purpose",
                "callback": "set-content-type",
                "sensitive_purpose": bool(sensitive_purpose),
                "surface": ADAPTER_CALLBACK_LEDGER_SURFACE,
                "redacted": True,
            }
        )

    def cursor_location(self, has_cursor_rect: bool) -> None:
        self._record(
            {
                "event": "cursor-location",
                "callback": "set-cursor-location",
                "has_cursor_rect": bool(has_cursor_rect),
                "surface": ADAPTER_CALLBACK_LEDGER_SURFACE,
                "redacted": True,
            }
        )

    def capabilities(self, lookup_table: bool, surrounding_text: bool) -> None:
        self._record(
            {
                "event": "client-capabilities",
                "callback": "set-capabilities",
                "lookup_table": bool(lookup_table),
                "surrounding_text": bool(surrounding_text),
                "surface": ADAPTER_CALLBACK_LEDGER_SURFACE,
                "redacted": True,
            }
        )

    def native_candidate_popup(
        self,
        *,
        action: str,
        published: bool,
        generation: int,
        has_cursor_rect: bool,
        lookup_table_capability: bool,
        expected_replacement: bool,
        hint_published: bool,
    ) -> None:
        self._record(
            {
                "event": "native-candidate-popup",
                "renderer": NATIVE_IBUS_LOOKUP_RENDERER,
                "action": action,
                "published": bool(published),
                "generation": max(1, int(generation)),
                "has_cursor_rect": bool(has_cursor_rect),
                "lookup_table_capability": bool(lookup_table_capability),
                "expected_replacement": bool(expected_replacement),
                "hint_published": bool(hint_published),
                "surface": ADAPTER_CALLBACK_LEDGER_SURFACE,
                "redacted": True,
            }
        )

    def publish(self, intent: dict[str, Any]) -> bool:
        self._record(
            {
                "event": "render-intent",
                "callback": "render-intent",
                "action": intent.get("action"),
                "reason": intent.get("reason"),
                "has_layout": bool(intent.get("has_layout", False)),
                "surface": ADAPTER_CALLBACK_LEDGER_SURFACE,
                "render_intent_surface": intent.get("surface"),
                "style_class": intent.get("style_class"),
                "font_family": intent.get("font_family"),
                "rendered_bubble_ready_claim": False,
                "live_overlay_claim": False,
                "live_ibus_bus_claim": False,
                "text_input_v3_claim": False,
                "runtime_ready_claim": False,
                "redacted": True,
            }
        )
        return True

    def payload(self) -> dict[str, Any]:
        callbacks = [
            record["callback"]
            for record in self.records
            if record.get("event") == "callback" and isinstance(record.get("callback"), str)
        ]
        callbacks_exercised = sorted(set(callbacks))
        operation_types = sorted(
            {
                operation_type
                for record in self.records
                for operation_type in record.get("operation_types", [])
                if isinstance(operation_type, str)
            }
        )
        render_intent_count = sum(
            1 for record in self.records if record.get("event") == "render-intent"
        )
        table_reload_count = sum(
            1 for record in self.records if record.get("event") == "table-reload"
        )
        sensitive_purpose_seen = any(
            record.get("event") == "content-purpose"
            and record.get("sensitive_purpose") is True
            for record in self.records
        )
        native_candidate_popup_count = sum(
            1
            for record in self.records
            if record.get("event") == "native-candidate-popup"
        )
        return {
            "status": "pass",
            "surface": ADAPTER_CALLBACK_LEDGER_SURFACE,
            "records": self.records,
            "record_count": len(self.records),
            "callbacks": callbacks,
            "callbacks_exercised": callbacks_exercised,
            "operation_types": operation_types,
            "render_intent_count": render_intent_count,
            "table_reload_count": table_reload_count,
            "sensitive_purpose_seen": sensitive_purpose_seen,
            "native_candidate_popup_count": native_candidate_popup_count,
            "value_redacted": True,
            "no_typed_text_logged": True,
            "rendered_bubble_ready_claim": False,
            "live_overlay_claim": False,
            "live_ibus_bus_claim": False,
            "text_input_v3_claim": False,
            "runtime_ready_claim": False,
        }

    def _record(self, record: dict[str, Any]) -> None:
        self.records.append(record)
        if self.path is None:
            return
        with open(self.path, "a", encoding="utf-8") as ledger_file:
            ledger_file.write(json.dumps(record, sort_keys=True, separators=(",", ":")))
            ledger_file.write("\n")


class NativeIbusLookupRenderer(CandidateBubbleRenderIntentSink):
    """Publishes one real candidate through the session's native IBus panel.

    IBus and GNOME Shell own cursor anchoring, monitor clamping, text scaling,
    accessibility, theme, and reduced-motion behavior. This class never creates
    a second GTK window and never logs replacement text.
    """

    def __init__(
        self,
        engine: Any,
        ibus: Any,
        proof_ledger: RedactedAdapterCallbackLedger | None = None,
        has_cursor_rect: Callable[[], bool] | None = None,
        lookup_table_capability: Callable[[], bool] | None = None,
    ) -> None:
        self._engine = engine
        self._ibus = ibus
        self._proof_ledger = proof_ledger
        self._has_cursor_rect = has_cursor_rect or (lambda: False)
        self._lookup_table_capability = lookup_table_capability or (lambda: False)
        self._lookup_table: Any | None = None
        self._generation = 0

    def publish(self, intent: dict[str, Any]) -> bool:
        action = intent.get("action")
        replacement = intent.get("replacement")
        if action not in {"show-candidate", "hide-candidate"}:
            raise ValueError("unsupported native IBus candidate action")
        if action == "show-candidate" and (
            not isinstance(replacement, str) or not replacement
        ):
            raise ValueError("native IBus candidate requires replacement text")

        self._generation += 1
        generation = self._generation
        expected_replacement = bool(
            isinstance(replacement, str)
            and hashlib.sha256(replacement.encode("utf-8")).hexdigest()
            == PROOF_EXPECTED_REPLACEMENT_SHA256
        )
        if self._proof_ledger is not None:
            self._proof_ledger.publish(intent)

        hint_published = False
        published = False
        try:
            if action == "show-candidate":
                lookup_table = self._ibus.LookupTable.new(1, 0, False, False)
                lookup_table.append_candidate(
                    self._ibus.Text.new_from_string(replacement)
                )
                lookup_table.append_label(self._ibus.Text.new_from_string("Space"))
                orientation = getattr(
                    getattr(self._ibus, "Orientation", object()),
                    "SYSTEM",
                    None,
                )
                if orientation is not None:
                    lookup_table.set_orientation(orientation)
                self._engine.update_lookup_table(lookup_table, True)
                self._lookup_table = lookup_table
                published = True
                try:
                    self._engine.update_auxiliary_text(
                        self._ibus.Text.new_from_string(NATIVE_IBUS_LOOKUP_HINT),
                        True,
                    )
                    hint_published = True
                except Exception:  # pragma: no cover - optional native hint.
                    hint_published = False
            else:
                published, hint_published = self._hide_native()
                if not published:
                    raise RuntimeError("native IBus lookup table did not hide")
        except Exception:
            if self._proof_ledger is not None:
                self._proof_ledger.native_candidate_popup(
                    action=action,
                    published=False,
                    generation=generation,
                    has_cursor_rect=self._has_cursor_rect(),
                    lookup_table_capability=self._lookup_table_capability(),
                    expected_replacement=expected_replacement,
                    hint_published=hint_published,
                )
            raise

        if self._proof_ledger is not None:
            self._proof_ledger.native_candidate_popup(
                action=action,
                published=published,
                generation=generation,
                has_cursor_rect=self._has_cursor_rect(),
                lookup_table_capability=self._lookup_table_capability(),
                expected_replacement=expected_replacement,
                hint_published=hint_published,
            )
        return True

    def force_hide(self) -> bool:
        """Retryable lifecycle hide that does not depend on candidate metadata."""
        published, _hint_published = self._hide_native()
        return published

    def _hide_native(self) -> tuple[bool, bool]:
        published = False
        hint_published = False
        try:
            self._engine.hide_lookup_table()
            self._lookup_table = None
            published = True
        except Exception:  # pragma: no cover - defensive GI boundary.
            published = False
        try:
            self._engine.hide_auxiliary_text()
            hint_published = True
        except Exception:  # pragma: no cover - optional native hint.
            hint_published = False
        return published, hint_published


def _proof_event_sink_from_env() -> RedactedAdapterCallbackLedger | None:
    path = os.environ.get("GOBLINS_TEXTSHORTCUTS_PROOF_EVENTS")
    if not path:
        return None
    return RedactedAdapterCallbackLedger(path)


class CandidateBubbleRenderIntentController:
    def __init__(
        self,
        sink: CandidateBubbleRenderIntentSink | None = None,
        anchor_provider: Callable[[], dict[str, Any] | None] | None = None,
        monitor_provider: Callable[[], dict[str, Any] | None] | None = None,
    ) -> None:
        self._sink = sink or CandidateBubbleRenderIntentSink()
        self._anchor_provider = anchor_provider or (lambda: None)
        self._monitor_provider = monitor_provider or (lambda: None)

    def emit_state(self, candidate_state: CandidateMetadataState | None) -> bool:
        if candidate_state is None:
            return True
        return self.emit_overlay_intent(candidate_state.last_overlay_intent)

    def clear(self, candidate_state: CandidateMetadataState, reason: str) -> None:
        candidate_state.clear(reason)
        self.emit_state(candidate_state)
        force_hide = getattr(self._sink, "force_hide", None)
        if callable(force_hide):
            try:
                force_hide()
            except Exception:  # pragma: no cover - defensive GI boundary.
                print(
                    "goblins-textshortcuts-ibus: forced candidate hide failed",
                    file=sys.stderr,
                )

    def emit_overlay_intent(self, overlay_intent: dict[str, Any] | None) -> bool:
        if overlay_intent is None:
            return True
        frame = _candidate_bubble_frame_from_intent(overlay_intent)
        if frame is None:
            return False
        layout = self._layout_for_frame(frame)
        record = {
            "surface": ACCEPT_BUBBLE_RENDER_INTENT_SURFACE,
            "frame_surface": ACCEPT_BUBBLE_FRAME_SURFACE,
            "layout_surface": ACCEPT_BUBBLE_LAYOUT_SURFACE,
            "action": frame["action"],
            "replacement": frame["replacement"],
            "accept_on": "word-boundary",
            "accept_keys": ["Space", "Return"],
            "dismiss_key": "Escape",
            "reason": frame["reason"],
            "style_class": ACCEPT_BUBBLE_STYLE_CLASS,
            "text_style_class": ACCEPT_BUBBLE_TEXT_STYLE_CLASS,
            "hint_style_class": ACCEPT_BUBBLE_HINT_STYLE_CLASS,
            "font_family": "Inter",
            "frame": frame,
            "layout": layout,
            "has_layout": layout is not None,
            "rendered_bubble_ready_claim": False,
            "live_overlay_claim": False,
            "runtime_ready_claim": False,
        }
        try:
            return self._sink.publish(record) is not False
        except Exception:  # pragma: no cover - defensive GI boundary.
            print(
                "goblins-textshortcuts-ibus: render intent sink failed",
                file=sys.stderr,
            )
            return False

    def _layout_for_frame(self, frame: dict[str, Any]) -> dict[str, Any] | None:
        if frame.get("action") == "hide-candidate":
            return _candidate_bubble_layout_from_frame(frame, {}, {})
        anchor = self._anchor_provider()
        monitor = self._monitor_provider()
        if anchor is None or monitor is None:
            return None
        return _candidate_bubble_layout_from_frame(frame, anchor, monitor)


class RuntimeStatusPublisher:
    """Publishes one redacted, fixed-path liveness record for the session bridge."""

    def __init__(self, path: str = RUNTIME_STATUS_PATH) -> None:
        self._path = path
        self._instance_id = secrets.token_hex(16)
        self._focus_generation = 0
        self._runtime_generation = 0
        self._sequence = 0
        self._focused = False
        self._enabled = False
        self._surrounding_text_supported = False
        self._snapshot_valid = False
        self._child_alive = False
        self._last_response_ok = False
        self._publish()

    def set_focused(self, focused: bool) -> None:
        focused = bool(focused)
        if focused and not self._focused:
            self._focus_generation += 1
        self._focused = focused
        if not focused:
            self._snapshot_valid = False
            self._last_response_ok = False
        self._publish()

    def set_enabled(self, enabled: bool) -> None:
        self._enabled = bool(enabled)
        if not self._enabled:
            self._snapshot_valid = False
            self._last_response_ok = False
        self._publish()

    def set_surrounding_text_supported(self, supported: bool) -> None:
        self._surrounding_text_supported = bool(supported)
        if not self._surrounding_text_supported:
            self._snapshot_valid = False
            self._last_response_ok = False
        self._publish()

    def set_snapshot_valid(self, valid: bool) -> None:
        self._snapshot_valid = bool(valid)
        if not self._snapshot_valid:
            self._last_response_ok = False
        self._publish()

    def runtime_transport(
        self,
        child_alive: bool,
        response_ok: bool,
        runtime_generation: int,
    ) -> None:
        generation_changed = runtime_generation != self._runtime_generation
        self._child_alive = bool(child_alive)
        self._runtime_generation = max(0, int(runtime_generation))
        if generation_changed or not child_alive or not response_ok:
            self._last_response_ok = False
        self._publish()

    def protocol_ready(self, runtime_generation: int) -> None:
        if (
            self._focused
            and self._enabled
            and self._surrounding_text_supported
            and self._snapshot_valid
            and self._child_alive
            and runtime_generation == self._runtime_generation
            and runtime_generation > 0
        ):
            self._last_response_ok = True
        self._publish()

    def is_focused(self) -> bool:
        return self._focused

    def _publish(self) -> None:
        self._sequence += 1
        payload = {
            "schema": RUNTIME_STATUS_SCHEMA,
            "instance_id": self._instance_id,
            "focus_generation": self._focus_generation,
            "runtime_generation": self._runtime_generation,
            "sequence": self._sequence,
            "monotonic_ns": time.monotonic_ns(),
            "focused": self._focused,
            "enabled": self._enabled,
            "surrounding_text_supported": self._surrounding_text_supported,
            "snapshot_valid": self._snapshot_valid,
            "child_alive": self._child_alive,
            "last_response_ok": self._last_response_ok,
        }
        raw = (json.dumps(payload, separators=(",", ":"), sort_keys=True) + "\n").encode(
            "utf-8"
        )
        if len(raw) > RUNTIME_STATUS_MAX_BYTES:
            return
        parent = os.path.dirname(self._path)
        name = os.path.basename(self._path)
        if not parent or not name:
            return
        directory_flags = os.O_RDONLY | os.O_CLOEXEC
        if hasattr(os, "O_DIRECTORY"):
            directory_flags |= os.O_DIRECTORY
        if hasattr(os, "O_NOFOLLOW"):
            directory_flags |= os.O_NOFOLLOW
        try:
            directory = os.open(parent, directory_flags)
        except OSError:
            return
        temporary = f".{name}.tmp-{secrets.token_hex(16)}"
        descriptor = -1
        try:
            metadata = os.fstat(directory)
            if (
                not stat.S_ISDIR(metadata.st_mode)
                or metadata.st_uid != os.geteuid()
                or metadata.st_mode & 0o007
            ):
                return
            file_flags = os.O_WRONLY | os.O_CREAT | os.O_EXCL | os.O_CLOEXEC
            if hasattr(os, "O_NOFOLLOW"):
                file_flags |= os.O_NOFOLLOW
            descriptor = os.open(
                temporary,
                file_flags,
                0o600,
                dir_fd=directory,
            )
            os.fchmod(descriptor, 0o600)
            view = memoryview(raw)
            while view:
                written = os.write(descriptor, view)
                if written <= 0:
                    raise OSError("short runtime-status write")
                view = view[written:]
            os.fsync(descriptor)
            os.close(descriptor)
            descriptor = -1
            os.rename(
                temporary,
                name,
                src_dir_fd=directory,
                dst_dir_fd=directory,
            )
            os.fsync(directory)
        except OSError:
            try:
                os.unlink(temporary, dir_fd=directory)
            except OSError:
                pass
        finally:
            if descriptor >= 0:
                os.close(descriptor)
            os.close(directory)


class RuntimeBridge:
    def __init__(
        self,
        argv: list[str] | None = None,
        response_timeout: float = RESPONSE_TIMEOUT_SECONDS,
        health_callback: Callable[[bool, bool, int], None] | None = None,
    ) -> None:
        self._argv = argv or _runtime_argv()
        self._response_timeout = response_timeout
        self._process: subprocess.Popen[bytes] | None = None
        self._health_callback = health_callback
        self._failure_count = 0
        self._next_restart_at = 0.0
        self._runtime_generation = 0
        self._last_response_ok = False

    def send(self, request: dict[str, Any]) -> dict[str, Any]:
        if time.monotonic() < self._next_restart_at:
            self._publish_health(False, False)
            return _passthrough_response()
        process = self._ensure_process()
        if process is None or process.stdin is None or process.stdout is None:
            return _passthrough_response()
        try:
            if select.select([process.stdout], [], [], 0)[0]:
                self._mark_failed("runtime emitted unsolicited response bytes")
                return _passthrough_response()
            payload = (
                json.dumps(request, separators=(",", ":"), ensure_ascii=False).encode("utf-8")
                + b"\n"
            )
            if len(payload) > RUNTIME_REQUEST_MAX_BYTES:
                self._mark_failed("runtime request exceeds the fixed size limit")
                return _passthrough_response()
            self._write_request_frame(process.stdin, payload)
            frame = self._read_response_frame(process.stdout)
            response = json.loads(frame.decode("utf-8"))
            if not _runtime_response_valid_for_request(request, response):
                self._mark_failed("runtime returned an invalid response object")
                return _passthrough_response()
            self._failure_count = 0
            self._next_restart_at = 0.0
            self._last_response_ok = True
            self._publish_health(True, True)
            return response
        except (
            BrokenPipeError,
            OSError,
            UnicodeDecodeError,
            UnicodeEncodeError,
            ValueError,
            json.JSONDecodeError,
        ) as error:
            self._mark_failed(f"runtime bridge failed: {error}")
            return _passthrough_response()

    def close(self) -> None:
        self._close_process()
        self._last_response_ok = False
        self._publish_health(False, False)

    def _close_process(self) -> None:
        process = self._process
        self._process = None
        if process is None:
            return
        process.terminate()
        try:
            process.wait(timeout=0.5)
        except subprocess.TimeoutExpired:
            process.kill()
            process.wait(timeout=0.5)

    def _ensure_process(self) -> subprocess.Popen[bytes] | None:
        if self._process is not None and self._process.poll() is None:
            return self._process
        if self._process is not None:
            self._mark_failed("runtime child exited")
            return None
        if time.monotonic() < self._next_restart_at:
            return None
        try:
            self._process = subprocess.Popen(
                self._argv,
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                bufsize=0,
            )
        except OSError as error:
            self._mark_failed(f"could not start runtime: {error}")
            return None
        self._runtime_generation += 1
        os.set_blocking(self._process.stdin.fileno(), False)
        os.set_blocking(self._process.stdout.fileno(), False)
        self._publish_health(True, False)
        return self._process

    def _mark_failed(self, message: str) -> None:
        print(f"goblins-textshortcuts-ibus: {message}", file=sys.stderr)
        self._close_process()
        self._last_response_ok = False
        self._failure_count = min(self._failure_count + 1, 8)
        backoff = min(
            RUNTIME_RESTART_BASE_SECONDS * (2 ** (self._failure_count - 1)),
            RUNTIME_RESTART_MAX_SECONDS,
        )
        self._next_restart_at = time.monotonic() + backoff
        self._publish_health(False, False)

    def _write_request_frame(self, stdin: Any, payload: bytes) -> None:
        deadline = time.monotonic() + self._response_timeout
        descriptor = stdin.fileno()
        offset = 0
        while offset < len(payload):
            remaining = deadline - time.monotonic()
            if remaining <= 0:
                raise OSError("runtime request write did not complete before timeout")
            _, writable, _ = select.select([], [stdin], [], remaining)
            if not writable:
                raise OSError("runtime request write did not complete before timeout")
            try:
                written = os.write(descriptor, payload[offset:])
            except BlockingIOError:
                continue
            if written <= 0:
                raise OSError("runtime request pipe closed before the request completed")
            offset += written

    def _read_response_frame(self, stdout: Any) -> bytes:
        deadline = time.monotonic() + self._response_timeout
        response = bytearray()
        descriptor = stdout.fileno()
        while True:
            newline = response.find(b"\n")
            if newline >= 0:
                if newline > RUNTIME_RESPONSE_MAX_BYTES:
                    raise OSError("runtime response exceeds the fixed size limit")
                if response[newline + 1 :]:
                    raise OSError("runtime returned extra response framing")
                if select.select([stdout], [], [], 0)[0]:
                    extra = os.read(descriptor, 1)
                    if extra:
                        raise OSError("runtime returned extra response framing")
                return bytes(response[:newline])
            remaining = deadline - time.monotonic()
            if remaining <= 0:
                raise OSError("runtime did not complete one response before timeout")
            readable, _, _ = select.select([stdout], [], [], remaining)
            if not readable:
                raise OSError("runtime did not complete one response before timeout")
            try:
                chunk = os.read(descriptor, 4096)
            except BlockingIOError:
                continue
            if not chunk:
                raise OSError("runtime closed stdout before one complete response")
            response.extend(chunk)
            if len(response) > RUNTIME_RESPONSE_MAX_BYTES:
                raise OSError("runtime response exceeds the fixed size limit")

    def _publish_health(self, child_alive: bool, response_ok: bool) -> None:
        if self._health_callback is not None:
            self._health_callback(
                bool(child_alive),
                bool(response_ok),
                self._runtime_generation,
            )

    def runtime_generation(self) -> int:
        return self._runtime_generation

    def last_response_ok(self) -> bool:
        return self._last_response_ok


def _passthrough_response() -> dict[str, Any]:
    return {
        "handled": False,
        # If the child runtime fails while a candidate is visible, clear the
        # native lookup table while returning the key fail-open. The defensive
        # preedit hide also cleans up stale state from an older adapter version.
        "operations": [{"type": "hide-preedit-text"}],
        "error": None,
        "runtime_available": False,
    }


def _strict_runtime_int(value: Any) -> bool:
    return isinstance(value, int) and not isinstance(value, bool)


def _validated_runtime_response_operations(
    response: Any,
    *,
    allow_synthetic_passthrough: bool = False,
) -> list[dict[str, Any]] | None:
    """Decode the child response without coercion before any GI-side mutation."""
    if not isinstance(response, dict):
        return None
    allowed_keys = {"handled", "operations", "candidate", "error"}
    synthetic = "runtime_available" in response
    if synthetic:
        if not allow_synthetic_passthrough or response.get("runtime_available") is not False:
            return None
        allowed_keys.add("runtime_available")
    if set(response) - allowed_keys or not {"handled", "operations"}.issubset(response):
        return None
    handled = response.get("handled")
    operations = response.get("operations")
    candidate = response.get("candidate")
    error = response.get("error")
    if not isinstance(handled, bool) or not isinstance(operations, list):
        return None
    if len(operations) > 3:
        return None
    if error is not None:
        if (
            not _runtime_text_is_safe(error)
            or handled
            or operations
            or candidate is not None
            or synthetic
        ):
            return None
        return []

    operation_types: list[str] = []
    for operation in operations:
        if not isinstance(operation, dict) or not isinstance(operation.get("type"), str):
            return None
        operation_type = operation["type"]
        operation_types.append(operation_type)
        if operation_type == "hide-preedit-text":
            if set(operation) != {"type"}:
                return None
        elif operation_type == "delete-surrounding-text":
            if set(operation) != {
                "type",
                "offset",
                "n_chars",
                "expected_text",
            }:
                return None
            expected_text = operation.get("expected_text")
            offset = operation.get("offset")
            n_chars = operation.get("n_chars")
            if (
                not _runtime_text_is_safe(expected_text)
                or not _strict_runtime_int(offset)
                or not _strict_runtime_int(n_chars)
                or offset != -len(expected_text)
                or n_chars != len(expected_text)
            ):
                return None
        elif operation_type == "commit-text":
            if set(operation) != {"type", "text"}:
                return None
            if not _runtime_text_is_safe(operation.get("text")):
                return None
        else:
            return None

    if operation_types not in (
        [],
        ["hide-preedit-text"],
        ["delete-surrounding-text", "commit-text", "hide-preedit-text"],
    ):
        return None

    if candidate is not None:
        if not isinstance(candidate, dict) or set(candidate) != {
            "trigger",
            "replacement",
            "accept_on",
            "dismiss_key",
            "rendered_bubble_ready_claim",
        }:
            return None
        if (
            not _runtime_text_is_safe(candidate.get("trigger"))
            or not _runtime_text_is_safe(candidate.get("replacement"))
            or candidate.get("accept_on") != "word-boundary"
            or candidate.get("dismiss_key") != "Escape"
            or candidate.get("rendered_bubble_ready_claim") is not False
            or handled
            or operations
        ):
            return None

    if synthetic and (
        handled
        or operation_types != ["hide-preedit-text"]
        or set(response) != {
            "handled",
            "operations",
            "error",
            "runtime_available",
        }
    ):
        return None
    return operations


def _runtime_response_valid_for_request(request: Any, response: Any) -> bool:
    operations = _validated_runtime_response_operations(response)
    if operations is None or response.get("error") is not None:
        return False
    if not isinstance(request, dict) or not isinstance(request.get("type"), str):
        return False
    request_type = request["type"]
    operation_types = [operation["type"] for operation in operations]
    handled = response["handled"]
    candidate = response.get("candidate")
    if request_type == "health":
        return not handled and not operations and candidate is None
    if request_type in {
        "focus-in",
        "focus-out",
        "reset",
        "content-purpose-changed",
        "table-changed",
    }:
        return (
            not handled
            and candidate is None
            and operation_types in ([], ["hide-preedit-text"])
        )
    if request_type == "accept-candidate":
        return candidate is None and (
            (not handled and not operations)
            or (
                handled
                and operation_types
                == ["delete-surrounding-text", "commit-text", "hide-preedit-text"]
            )
        )
    if request_type != "key":
        return False
    if not operations:
        if candidate is None:
            return not handled
        unicode_value = request.get("unicode")
        return bool(
            not handled
            and request.get("pressed") is True
            and request.get("command_modifier_active") is False
            and isinstance(unicode_value, str)
            and len(unicode_value) == 1
            and _request_boundary(request) is None
            and candidate["trigger"].endswith(unicode_value)
        )
    if operation_types == ["hide-preedit-text"]:
        return (not handled) or (
            handled
            and request.get("pressed") is True
            and request.get("keyval") == IBUS_KEY_ESCAPE
        )
    if operation_types == [
        "delete-surrounding-text",
        "commit-text",
        "hide-preedit-text",
    ]:
        forwards_boundary = request.get("keyval") in {IBUS_KEY_TAB, IBUS_KEY_RETURN}
        return handled != forwards_boundary
    return False


def _runtime_response_ok(response: dict[str, Any]) -> bool:
    return bool(
        _validated_runtime_response_operations(
            response,
            allow_synthetic_passthrough=True,
        )
        is not None
        and response.get("error") is None
        and response.get("runtime_available") is not False
    )


def _key_request(keyval: int, state: int, ibus: Any) -> dict[str, Any]:
    release_mask = int(getattr(ibus.ModifierType, "RELEASE_MASK", 1 << 30))
    pressed = (state & release_mask) == 0
    return {
        "type": "key",
        "keyval": int(keyval),
        "unicode": _unicode_for_keyval(keyval, ibus) if pressed else None,
        "pressed": pressed,
        "command_modifier_active": _command_modifier_active(state, ibus),
    }


def _unicode_for_keyval(keyval: int, ibus: Any) -> str | None:
    unicode_value = ibus.keyval_to_unicode(keyval)
    if isinstance(unicode_value, str):
        if len(unicode_value) != 1:
            return None
        codepoint = ord(unicode_value)
    else:
        try:
            codepoint = int(unicode_value)
        except (TypeError, ValueError, OverflowError):
            return None
    if (
        codepoint < 0x20
        or 0xD800 <= codepoint <= 0xDFFF
        or codepoint > 0x10FFFF
    ):
        return None
    return chr(codepoint)


def _command_modifier_active(state: int, ibus: Any) -> bool:
    modifiers = (
        "CONTROL_MASK",
        "META_MASK",
        "MOD1_MASK",
        "MOD4_MASK",
        "SUPER_MASK",
        "HYPER_MASK",
    )
    for name in modifiers:
        value = getattr(ibus.ModifierType, name, None)
        if value is not None and state & int(value):
            return True
    return False


def _content_purpose_request(event_type: str, purpose: int) -> dict[str, Any]:
    return {"type": event_type, "purpose": int(purpose)}


def _input_hint_mask(ibus: Any, name: str, fallback: int) -> int:
    input_hints = getattr(ibus, "InputHints", None)
    value = getattr(input_hints, name, fallback)
    try:
        mask = int(value)
    except (TypeError, ValueError, OverflowError):
        return fallback
    return mask if 0 < mask <= 0xFFFFFFFF else fallback


def _effective_content_purpose(purpose: Any, hints: Any, ibus: Any) -> int:
    """Map private/hidden input to the existing fail-closed password contract."""
    try:
        if isinstance(purpose, bool) or isinstance(hints, bool):
            raise TypeError("boolean content type")
        purpose_value = int(purpose)
        hints_value = int(hints)
        if (
            purpose_value < 0
            or hints_value < 0
            or purpose_value > 0xFFFFFFFF
            or hints_value > 0xFFFFFFFF
        ):
            raise ValueError("content type outside guint32 range")
    except (TypeError, ValueError, OverflowError):
        return min(SENSITIVE_INPUT_PURPOSES)
    sensitive_hints = _input_hint_mask(
        ibus,
        "PRIVATE",
        IBUS_INPUT_HINT_PRIVATE_FALLBACK,
    ) | _input_hint_mask(
        ibus,
        "HIDDEN_TEXT",
        IBUS_INPUT_HINT_HIDDEN_TEXT_FALLBACK,
    )
    if purpose_value in SENSITIVE_INPUT_PURPOSES or hints_value & sensitive_hints:
        return min(SENSITIVE_INPUT_PURPOSES)
    return purpose_value


SurroundingTextSnapshot = tuple[str, int, int]


class FocusBoundSurroundingTextCache:
    """Owns only validated callback snapshots from the current focus lifetime."""

    def __init__(self) -> None:
        self._focus_generation = 0
        self._focused = False
        self._snapshot_generation = -1
        self._snapshot: SurroundingTextSnapshot | None = None

    def begin_focus(self) -> None:
        self._focus_generation += 1
        self._focused = True
        self.invalidate()

    def end_focus(self) -> None:
        self._focus_generation += 1
        self._focused = False
        self.invalidate()

    def observe(self, snapshot: SurroundingTextSnapshot) -> bool:
        if not self._focused:
            self.invalidate()
            return False
        self._snapshot = snapshot
        self._snapshot_generation = self._focus_generation
        return True

    def current(self) -> SurroundingTextSnapshot | None:
        if (
            not self._focused
            or self._snapshot_generation != self._focus_generation
        ):
            return None
        return self._snapshot

    def invalidate(self) -> None:
        self._snapshot_generation = -1
        self._snapshot = None


def _ibus_text_value(text: Any) -> str | None:
    if isinstance(text, str):
        return text
    getter = getattr(text, "get_text", None)
    if callable(getter):
        try:
            value = getter()
        except (TypeError, ValueError, RuntimeError):
            return None
        return value if isinstance(value, str) else None
    value = getattr(text, "text", None)
    return value if isinstance(value, str) else None


def _normalize_surrounding_text(
    text: Any,
    cursor_pos: Any,
    anchor_pos: Any,
) -> SurroundingTextSnapshot | None:
    value = _ibus_text_value(text)
    if (
        not _bounded_utf8_text(
            value,
            allow_empty=True,
            max_characters=SURROUNDING_TEXT_MAX_CHARACTERS,
            max_bytes=SURROUNDING_TEXT_MAX_BYTES,
        )
        or isinstance(cursor_pos, bool)
        or isinstance(anchor_pos, bool)
        or not isinstance(cursor_pos, int)
        or not isinstance(anchor_pos, int)
        or cursor_pos < 0
        or anchor_pos < 0
        or cursor_pos > len(value)
        or anchor_pos > len(value)
    ):
        return None
    return (value, cursor_pos, anchor_pos)


def _snapshot_after_insert(
    snapshot: SurroundingTextSnapshot,
    value: str,
) -> SurroundingTextSnapshot | None:
    text, cursor_pos, anchor_pos = snapshot
    if cursor_pos != anchor_pos or len(value) != 1:
        return None
    next_text = f"{text[:cursor_pos]}{value}{text[cursor_pos:]}"
    if not _bounded_utf8_text(
        next_text,
        allow_empty=True,
        max_characters=SURROUNDING_TEXT_MAX_CHARACTERS,
        max_bytes=SURROUNDING_TEXT_MAX_BYTES,
    ):
        return None
    return (
        next_text,
        cursor_pos + 1,
        cursor_pos + 1,
    )


def _snapshot_after_backspace(
    snapshot: SurroundingTextSnapshot,
) -> SurroundingTextSnapshot | None:
    text, cursor_pos, anchor_pos = snapshot
    if cursor_pos != anchor_pos or cursor_pos == 0:
        return None
    next_text = f"{text[: cursor_pos - 1]}{text[cursor_pos:]}"
    return (
        next_text,
        cursor_pos - 1,
        cursor_pos - 1,
    )


def _request_boundary(request: dict[str, Any]) -> str | None:
    if request.get("pressed") is not True:
        return None
    keyval = request.get("keyval")
    if keyval == IBUS_KEY_RETURN:
        return "\n"
    if keyval == IBUS_KEY_TAB:
        return "\t"
    value = request.get("unicode")
    if not isinstance(value, str) or len(value) != 1:
        return None
    if value.isspace() or value in ".,;:!?)]}":
        return value
    return None


def _replacement_operations(response: dict[str, Any]) -> list[dict[str, Any]]:
    operations = response.get("operations")
    if not isinstance(operations, list):
        return []
    return [operation for operation in operations if isinstance(operation, dict)]


def _response_has_destructive_replacement(response: dict[str, Any]) -> bool:
    operation_types = {
        operation.get("type") for operation in _replacement_operations(response)
    }
    return bool(
        operation_types.intersection(
            {"delete-surrounding-text", "commit-text"}
        )
    )


def _fail_open_replacement_response(response: dict[str, Any]) -> dict[str, Any]:
    fail_open = dict(response)
    fail_open["handled"] = False
    fail_open["operations"] = [{"type": "hide-preedit-text"}]
    fail_open["candidate"] = None
    return fail_open


class SurroundingTextCommitGuard:
    """Binds a replacement to one continuous, capability-backed text edit."""

    def __init__(self) -> None:
        self._supported = False
        self._expected_snapshot: SurroundingTextSnapshot | None = None
        self._tracked_word = ""
        self._candidate_trigger: str | None = None
        self._candidate_replacement: str | None = None
        self._candidate_anchor: SurroundingTextSnapshot | None = None
        self._candidate_anchor_confirmed = False
        self._commit_anchor: SurroundingTextSnapshot | None = None
        self._generation = 0

    def set_supported(self, supported: bool) -> bool:
        supported = bool(supported)
        lost_support = self._supported and not supported
        self._supported = supported
        if lost_support:
            self.reset()
        return lost_support

    def reset(self) -> None:
        self._expected_snapshot = None
        self._tracked_word = ""
        self._clear_candidate()

    def observe_surrounding(self, snapshot: SurroundingTextSnapshot | None) -> bool:
        if self._expected_snapshot is None:
            return False
        if snapshot != self._expected_snapshot:
            self.reset()
            return True
        if self._candidate_anchor == snapshot:
            self._candidate_anchor_confirmed = True
        return False

    def prepare_key(
        self,
        request: dict[str, Any],
        snapshot: SurroundingTextSnapshot | None,
    ) -> bool:
        self._commit_anchor = None
        if request.get("pressed") is not True:
            return False
        keyval = request.get("keyval")
        if request.get("command_modifier_active") is True or keyval in {
            IBUS_KEY_LEFT,
            IBUS_KEY_UP,
            IBUS_KEY_RIGHT,
            IBUS_KEY_DOWN,
            IBUS_KEY_DELETE,
            IBUS_KEY_ESCAPE,
        }:
            self.reset()
            return False

        if keyval == IBUS_KEY_BACKSPACE:
            if not self._can_continue(snapshot):
                had_tracking = bool(self._tracked_word or self._expected_snapshot)
                self.reset()
                return had_tracking or not self._supported
            expected = _snapshot_after_backspace(snapshot)
            if expected is None:
                self.reset()
                return True
            self._tracked_word = self._tracked_word[:-1]
            self._expected_snapshot = expected
            self._clear_candidate()
            return False

        boundary = _request_boundary(request)
        if boundary is not None:
            if not self._tracked_word:
                self.reset()
                return False
            if not self._can_continue(snapshot):
                self.reset()
                return True
            if (
                self._candidate_trigger == self._tracked_word
                and self._candidate_anchor == snapshot
                and self._candidate_anchor_confirmed
            ):
                self._commit_anchor = snapshot
                return False
            self.reset()
            return True

        value = request.get("unicode")
        if not isinstance(value, str) or len(value) != 1:
            return False
        if not self._supported or snapshot is None or snapshot[1] != snapshot[2]:
            self.reset()
            return True
        reset_runtime = self._expected_snapshot is not None and snapshot != self._expected_snapshot
        if reset_runtime:
            self.reset()
        expected = _snapshot_after_insert(snapshot, value)
        if expected is None:
            self.reset()
            return True
        self._tracked_word += value
        self._expected_snapshot = expected
        self._clear_candidate()
        return reset_runtime

    def prepare_candidate_accept(
        self,
        snapshot: SurroundingTextSnapshot | None,
    ) -> bool:
        self._commit_anchor = None
        if (
            self._can_continue(snapshot)
            and self._candidate_trigger == self._tracked_word
            and self._candidate_anchor == snapshot
            and self._candidate_anchor_confirmed
        ):
            self._commit_anchor = snapshot
            return True
        self.reset()
        return False

    def validate_response(
        self,
        request: dict[str, Any] | None,
        response: dict[str, Any],
        snapshot: SurroundingTextSnapshot | None,
    ) -> dict[str, Any]:
        if _response_has_destructive_replacement(response):
            if self._valid_replacement_transaction(request, response, snapshot):
                self.reset()
                return response
            self.reset()
            return _fail_open_replacement_response(response)

        candidate = response.get("candidate")
        if isinstance(candidate, dict):
            trigger = candidate.get("trigger")
            replacement = candidate.get("replacement")
            if (
                not isinstance(trigger, str)
                or not trigger
                or not isinstance(replacement, str)
                or not replacement
                or trigger != self._tracked_word
                or self._expected_snapshot is None
            ):
                self.reset()
                return _fail_open_replacement_response(response)
            self._generation += 1
            self._candidate_trigger = trigger
            self._candidate_replacement = replacement
            self._candidate_anchor = self._expected_snapshot
            self._candidate_anchor_confirmed = False

        if response.get("runtime_available") is False or response.get("error") is not None:
            self.reset()
            return response

        if request is not None:
            boundary = _request_boundary(request)
            if boundary is not None:
                if response.get("handled") is False and snapshot is not None:
                    self._expected_snapshot = _snapshot_after_insert(snapshot, boundary)
                else:
                    self._expected_snapshot = None
                self._tracked_word = ""
                self._clear_candidate()
        return response

    def _can_continue(self, snapshot: SurroundingTextSnapshot | None) -> bool:
        return bool(
            self._supported
            and snapshot is not None
            and snapshot[1] == snapshot[2]
            and self._expected_snapshot == snapshot
        )

    def _valid_replacement_transaction(
        self,
        request: dict[str, Any] | None,
        response: dict[str, Any],
        snapshot: SurroundingTextSnapshot | None,
    ) -> bool:
        if response.get("error") is not None:
            return False
        operations = _replacement_operations(response)
        if [operation.get("type") for operation in operations] != [
            "delete-surrounding-text",
            "commit-text",
            "hide-preedit-text",
        ]:
            return False
        delete = operations[0]
        trigger = delete.get("expected_text")
        if not isinstance(trigger, str) or not trigger:
            return False
        trigger_chars = len(trigger)
        boundary = _request_boundary(request) if request is not None else None
        expected_commit = self._candidate_replacement
        if (
            expected_commit is not None
            and boundary is not None
            and request.get("keyval") not in {IBUS_KEY_TAB, IBUS_KEY_RETURN}
        ):
            expected_commit = f"{expected_commit}{boundary}"
        if (
            isinstance(delete.get("offset"), bool)
            or isinstance(delete.get("n_chars"), bool)
            or delete.get("offset") != -trigger_chars
            or delete.get("n_chars") != trigger_chars
            or not isinstance(operations[1].get("text"), str)
            or expected_commit is None
            or operations[1].get("text") != expected_commit
            or trigger != self._tracked_word
            or trigger != self._candidate_trigger
            or not self._candidate_anchor_confirmed
            or snapshot is None
            or snapshot != self._expected_snapshot
            or snapshot != self._candidate_anchor
            or snapshot != self._commit_anchor
        ):
            return False
        text, cursor_pos, anchor_pos = snapshot
        return (
            cursor_pos == anchor_pos
            and cursor_pos >= trigger_chars
            and text[cursor_pos - trigger_chars : cursor_pos] == trigger
        )

    def _clear_candidate(self) -> None:
        self._candidate_trigger = None
        self._candidate_replacement = None
        self._candidate_anchor = None
        self._candidate_anchor_confirmed = False
        self._commit_anchor = None


def _send_table_changed_if_needed(
    table_bridge: ShortcutTableBridge,
    runtime_bridge: RuntimeBridge,
    target: Any,
    text_factory: Callable[[str], Any],
    candidate_state: CandidateMetadataState | None = None,
    render_controller: CandidateBubbleRenderIntentController | None = None,
    proof_ledger: RedactedAdapterCallbackLedger | None = None,
) -> tuple[bool, bool]:
    request = table_bridge.maybe_changed_request()
    if request is None:
        return (False, True)
    response = runtime_bridge.send(request)
    if not _runtime_response_ok(response):
        table_bridge.invalidate()
    if proof_ledger is not None:
        shortcuts = request.get("shortcuts", [])
        proof_ledger.table_reload(len(shortcuts) if isinstance(shortcuts, list) else 0)
    applied = _apply_response_operations_with_render_intent(
        target,
        response,
        text_factory,
        candidate_state,
        render_controller,
    )
    return (True, applied)


def _apply_response_operations(
    target: Any,
    response: dict[str, Any],
    text_factory: Callable[[str], Any],
    candidate_state: CandidateMetadataState | None = None,
) -> bool:
    operations = _validated_runtime_response_operations(
        response,
        allow_synthetic_passthrough=True,
    )
    if operations is None:
        return False
    prepared_text: dict[int, Any] = {}
    for index, operation in enumerate(operations):
        if operation["type"] != "commit-text":
            continue
        try:
            value = text_factory(operation["text"])
        except Exception:  # pragma: no cover - defensive GI boundary.
            return False
        if value is None:
            return False
        prepared_text[index] = value
    try:
        for index, operation in enumerate(operations):
            operation_type = operation.get("type")
            if operation_type == "hide-preedit-text":
                target.hide_preedit_text()
            elif operation_type == "delete-surrounding-text":
                target.delete_surrounding_text(
                    operation["offset"],
                    operation["n_chars"],
                )
            elif operation_type == "commit-text":
                target.commit_text(prepared_text[index])
    except Exception:  # pragma: no cover - defensive GI boundary.
        return False
    if candidate_state is not None:
        candidate_state.observe_response(response)
    return True


def _apply_response_operations_with_render_intent(
    target: Any,
    response: dict[str, Any],
    text_factory: Callable[[str], Any],
    candidate_state: CandidateMetadataState | None = None,
    render_controller: CandidateBubbleRenderIntentController | None = None,
) -> bool:
    if not _apply_response_operations(target, response, text_factory, candidate_state):
        return False
    if render_controller is not None:
        return render_controller.emit_state(candidate_state)
    return True


def _run_self_test() -> None:
    class FakeModifierType:
        RELEASE_MASK = 1 << 30
        CONTROL_MASK = 1 << 2
        MOD1_MASK = 1 << 3
        MOD4_MASK = 1 << 6

    class FakeIbus:
        ModifierType = FakeModifierType

        @staticmethod
        def keyval_to_unicode(keyval: int) -> int:
            if keyval == 0xFF0D:
                return 0
            return keyval

    class FakeStringIbus:
        ModifierType = FakeModifierType

        @staticmethod
        def keyval_to_unicode(keyval: int) -> str:
            if keyval == 0xFF0D:
                return ""
            return chr(keyval)

    class FakeSurrogateIbus:
        ModifierType = FakeModifierType

        @staticmethod
        def keyval_to_unicode(_keyval: int) -> int:
            return 0xD800

    assert _key_request(ord("o"), 0, FakeIbus) == {
        "type": "key",
        "keyval": ord("o"),
        "unicode": "o",
        "pressed": True,
        "command_modifier_active": False,
    }
    assert _key_request(ord("o"), 0, FakeStringIbus) == {
        "type": "key",
        "keyval": ord("o"),
        "unicode": "o",
        "pressed": True,
        "command_modifier_active": False,
    }
    assert _key_request(ord("o"), FakeModifierType.RELEASE_MASK, FakeIbus)[
        "pressed"
    ] is False
    assert _candidate_click_request(0, 1) == {"type": "accept-candidate"}
    assert _candidate_click_request(1, 1) is None
    assert _candidate_click_request(0, 3) is None
    assert _candidate_click_request(True, 1) is None
    assert _key_request(ord("w"), FakeModifierType.CONTROL_MASK, FakeIbus)[
        "command_modifier_active"
    ] is True
    assert _key_request(0xFF0D, 0, FakeIbus)["unicode"] is None
    assert _key_request(0xFF0D, 0, FakeStringIbus)["unicode"] is None
    assert _key_request(0x0100D800, 0, FakeSurrogateIbus)["unicode"] is None
    assert _content_purpose_request("content-purpose-changed", 9) == {
        "type": "content-purpose-changed",
        "purpose": 9,
    }
    assert _effective_content_purpose(0, 0, FakeIbus) == 0
    assert (
        _effective_content_purpose(
            0,
            IBUS_INPUT_HINT_PRIVATE_FALLBACK,
            FakeIbus,
        )
        == 8
    )
    assert (
        _effective_content_purpose(
            0,
            IBUS_INPUT_HINT_HIDDEN_TEXT_FALLBACK,
            FakeIbus,
        )
        == 8
    )
    assert _effective_content_purpose(0, "invalid", FakeIbus) == 8
    assert _effective_content_purpose(True, 0, FakeIbus) == 8
    assert _effective_content_purpose(0x100000000, 0, FakeIbus) == 8
    assert _effective_content_purpose(0, 0x100000000, FakeIbus) == 8
    assert _runtime_text_is_safe("on my way")
    assert _runtime_text_is_safe("line one\nline two")
    assert not _runtime_text_is_safe("x\x00y")
    assert not _runtime_text_is_safe("x\ud800y")
    assert not _runtime_text_is_safe("x" * (RUNTIME_TEXT_MAX_CHARACTERS + 1))
    bounded_surrounding = "x" * SURROUNDING_TEXT_MAX_CHARACTERS
    assert _normalize_surrounding_text(
        bounded_surrounding,
        len(bounded_surrounding),
        len(bounded_surrounding),
    ) == (
        bounded_surrounding,
        len(bounded_surrounding),
        len(bounded_surrounding),
    )
    assert (
        _normalize_surrounding_text(
            f"{bounded_surrounding}x",
            len(bounded_surrounding) + 1,
            len(bounded_surrounding) + 1,
        )
        is None
    )
    multibyte_surrounding = "é" * ((SURROUNDING_TEXT_MAX_BYTES // 2) + 1)
    assert _normalize_surrounding_text(
        multibyte_surrounding,
        len(multibyte_surrounding),
        len(multibyte_surrounding),
    ) is None
    callback_snapshot: SurroundingTextSnapshot = ("typed here", 10, 10)
    snapshot_cache = FocusBoundSurroundingTextCache()
    assert snapshot_cache.current() is None
    snapshot_cache.begin_focus()
    assert snapshot_cache.observe(callback_snapshot) is True
    assert snapshot_cache.current() == callback_snapshot
    snapshot_cache.end_focus()
    assert snapshot_cache.current() is None
    snapshot_cache.begin_focus()
    assert snapshot_cache.current() is None
    snapshot_cache.invalidate()
    assert snapshot_cache.current() is None
    assert _candidate_metadata_from_response(
        {
            "candidate": {
                "trigger": "omw",
                "replacement": "on my way",
                "accept_on": "word-boundary",
                "dismiss_key": "Escape",
                "rendered_bubble_ready_claim": False,
            }
        }
    ) == {
        "replacement": "on my way",
        "accept_on": "word-boundary",
        "dismiss_key": "Escape",
        "rendered_bubble_ready_claim": False,
    }
    assert _candidate_metadata_from_response(
        {
            "candidate": {
                "trigger": "omw",
                "replacement": "on my way",
                "accept_on": "word-boundary",
                "dismiss_key": "Escape",
                "rendered_bubble_ready_claim": True,
            }
        }
    ) is None

    def guard_key(value: str) -> dict[str, Any]:
        return {
            "type": "key",
            "keyval": ord(value),
            "unicode": value,
            "pressed": True,
