                runtime.send(_content_purpose_request("focus-in", 0)),
                text_factory,
                candidate_state,
            )

            for character in "omw":
                response = runtime.send(_key_request(ord(character), 0, IBus))
                _apply_response_operations(
                    target,
                    response,
                    text_factory,
                    candidate_state,
                )
            preedit_update = (
                response.get("candidate", {}).get("replacement") == "on my way"
                and any(
                    call[0] == "update" and call[2:] == (9, True)
                    for call in target.calls
                )
            )

            _apply_response_operations(
                target,
                runtime.send(_key_request(0xFF1B, 0, IBus)),
                text_factory,
                candidate_state,
            )
            escape_dismiss = target.calls[-1:] == [("hide",)] and candidate_state.current is None

            target.calls.clear()
            for character in "omw ":
                response = runtime.send(_key_request(ord(character), 0, IBus))
                _apply_response_operations(
                    target,
                    response,
                    text_factory,
                    candidate_state,
                )
            boundary_commit = (
                response.get("handled") is True
                and any(
                    operation.get("type") == "commit-text"
                    and operation.get("text") == "on my way "
                    for operation in response.get("operations", [])
                    if isinstance(operation, dict)
                )
                and [call[0] for call in target.calls]
                == ["update", "delete", "commit", "hide"]
                and ("delete", -3, 3) in target.calls
            )

            target.calls.clear()
            pass_through_default = True
            for character in "hello ":
                response = runtime.send(_key_request(ord(character), 0, IBus))
                pass_through_default = pass_through_default and response.get("handled") is False
                _apply_response_operations(target, response, text_factory, candidate_state)
            pass_through_default = pass_through_default and target.calls == []

            runtime.send(_content_purpose_request("content-purpose-changed", 9))
            target.calls.clear()
            password_refusal = True
            for character in "omw ":
                response = runtime.send(_key_request(ord(character), 0, IBus))
                password_refusal = password_refusal and response.get("handled") is False
                _apply_response_operations(target, response, text_factory, candidate_state)
            password_refusal = password_refusal and target.calls == []

            _apply_response_operations(
                target,
                runtime.send({"type": "focus-out"}),
                text_factory,
                candidate_state,
            )
            _apply_response_operations(
                target,
                runtime.send({"type": "reset"}),
                text_factory,
                candidate_state,
            )
        finally:
            runtime.close()

    payload = {
        "status": "pass",
        "surface": GI_ADAPTER_CONTRACT_SURFACE,
        "adapter_entrypoint": ADAPTER_PATH,
        "component_exec": ADAPTER_PATH,
        "engine_name": ENGINE_NAME,
        "gi_ibus_import": True,
        "ibus_text_factory": "IBus.Text.new_from_string",
        "ibus_key_unicode": True,
        "callbacks_exercised": callbacks_exercised,
        "preedit_update": preedit_update,
        "boundary_commit": boundary_commit,
        "escape_dismiss": escape_dismiss,
        "pass_through_default": pass_through_default,
        "password_refusal": password_refusal,
        "render_intent_surface": render_contract["surface"],
        "render_intent_count": render_contract["render_intent_count"],
        "rendered_bubble_ready_claim": False,
        "live_overlay_claim": False,
        "live_ibus_bus_claim": False,
        "text_input_v3_claim": False,
        "runtime_ready_claim": False,
    }
    assert payload["preedit_update"] is True
    assert payload["boundary_commit"] is True
    assert payload["escape_dismiss"] is True
    assert payload["pass_through_default"] is True
    assert payload["password_refusal"] is True
    assert payload["render_intent_surface"] == ACCEPT_BUBBLE_RENDER_INTENT_SURFACE
    assert payload["render_intent_count"] == 8
    assert payload["rendered_bubble_ready_claim"] is False
    assert payload["live_overlay_claim"] is False
    assert payload["live_ibus_bus_claim"] is False
    assert payload["text_input_v3_claim"] is False
    assert payload["runtime_ready_claim"] is False
    return payload


