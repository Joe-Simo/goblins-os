RUN test -x /usr/libexec/goblins-os/goblins-os-full-installer \
    && desktop-file-validate /usr/share/applications/org.goblins.OS.FullInstaller.desktop \
    && grep -q '^Exec=/usr/libexec/goblins-os/goblins-os-full-installer$' /usr/share/applications/org.goblins.OS.FullInstaller.desktop \
    && { test -x /usr/bin/liveinst || test -x /usr/bin/anaconda || test -x /usr/libexec/anaconda/run-anaconda; } \
    && test -x /usr/libexec/goblins-os/goblins-os-install-game-launcher \
    && for launcher_desktop in \
      /usr/share/applications/org.goblins.OS.Games.Heroic.desktop \
      /usr/share/applications/org.goblins.OS.Games.Bottles.desktop \
      /usr/share/applications/org.goblins.OS.Games.Lutris.desktop; do \
        desktop-file-validate "${launcher_desktop}"; \
        grep -q '^Exec=/usr/libexec/goblins-os/goblins-os-install-game-launcher ' "${launcher_desktop}"; \
      done
