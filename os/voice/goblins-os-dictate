#!/usr/bin/sh
# Goblins OS dictation — speak into any text field.
#
# Captures the microphone and transcribes it on-device through the local core
# (Whisper, no network), then types the recognized text into the focused field
# via the Wayland synthetic-input path (wtype). Honest-gating is end to end: if
# the core has no Whisper model / microphone, it returns ok=false and we type
# nothing rather than pretend. Bound to a desktop shortcut.
set -eu

CORE_URL="${GOBLINS_OS_CORE_URL:-http://127.0.0.1:8787}"

resp="$(curl -fsS -m 30 -X POST "${CORE_URL}/v1/voice/dictate" 2>/dev/null || true)"
[ -n "$resp" ] || exit 0

transcript="$(printf '%s' "$resp" | python3 -c 'import sys, json
try:
    d = json.load(sys.stdin)
except Exception:
    sys.exit(0)
if d.get("ok") and d.get("transcript"):
    sys.stdout.write(d["transcript"])
' 2>/dev/null || true)"

[ -n "$transcript" ] || exit 0
exec wtype -- "$transcript"
