[Unit]
Description=Goblins OS shell
CollectMode=inactive-or-failed

PartOf=org.goblins.OS.Shell.target
PartOf=gnome-session-initialized.target
After=gnome-session-initialized.target org.gnome.Shell@user.service

[Service]
Type=simple
Environment=GOBLINS_OS_SESSION=gnome-native-desktop
Environment=GOBLINS_OS_GUI_PLATFORM=gnome-session
Environment=GOBLINS_OS_SHELL_MODE=native-desktop
EnvironmentFile=-/etc/goblins-os/environment
ExecStart=/usr/libexec/goblins-os/goblins-os-shell
Restart=on-failure
RestartSec=1
