    && command -v fc-match \
    && command -v fc-list \
    && fc-match Inter | grep -qi 'Inter' \
    && ! fc-list | grep -Eiq 'OpenAI Sans|SF Pro|Apple' \
    && ! rpm -qa | grep -Eiq 'openai.*sans|sf-pro|apple.*font' \
    && flatpak remote-add --system --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo \
    && flatpak remotes --system | grep -q '^flathub' \
    && ! rpm -q steam >/dev/null 2>&1 \
    && ! rpm -q steam-devices >/dev/null 2>&1 \
