#!/usr/bin/env python3
"""Goblins OS Text Shortcuts IBus adapter.

This adapter owns the GI/IBus boundary and delegates replacement decisions to
the Rust runtime over the line-oriented JSON stdio protocol. It deliberately
keeps IBus errors fail-open: text input must continue as pass-through if the
Rust child is absent, exits, or returns invalid JSON.
"""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import select
import subprocess
import sys
import tempfile
from typing import Any, Callable


ENGINE_NAME = "goblins-textshortcuts"
COMPONENT_NAME = "org.goblins.OS.TextShortcuts"
RUNTIME_PATH = "/usr/libexec/goblins-os/goblins-textshortcuts-engine"
RESPONSE_TIMEOUT_SECONDS = 0.35
CAPABILITY_TIMEOUT_SECONDS = 3.0
ADAPTER_PATH = "/usr/libexec/goblins-os/goblins-textshortcuts-ibus"
OVERLAY_INTENT_PROOF_SURFACE = "goblins-textshortcuts-ibus-adapter-overlay-intent"
ACCEPT_BUBBLE_FRAME_SURFACE = "goblins-textshortcuts-accept-bubble-frame"
ACCEPT_BUBBLE_STYLE_CLASS = "gos-text-shortcuts-candidate"
ACCEPT_BUBBLE_TEXT_STYLE_CLASS = "gos-text-shortcuts-candidate-text"
ACCEPT_BUBBLE_HINT_STYLE_CLASS = "gos-text-shortcuts-candidate-hint"
TEXT_SHORTCUTS_CONFIG_DIR = "goblins-os"
TEXT_SHORTCUTS_CONFIG_FILE = "text-shortcuts.json"
MAX_SHORTCUTS = 500


def _runtime_binary() -> str:
    return os.environ.get("GOBLINS_TEXTSHORTCUTS_ENGINE", RUNTIME_PATH)


def _runtime_argv() -> list[str]:
    return [_runtime_binary(), "--stdio"]


def _runtime_stdio_self_test(argv: list[str] | None = None) -> bool:
    command = argv or [_runtime_binary(), "--stdio-self-test"]
    try:
        result = subprocess.run(
            command,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            encoding="utf-8",
            timeout=CAPABILITY_TIMEOUT_SECONDS,
        )
    except (OSError, subprocess.TimeoutExpired):
        return False
    return (
        result.returncode == 0
        and "goblins_textshortcuts_stdio_selftest ok" in result.stdout
    )


def capability_payload(runtime_self_test_argv: list[str] | None = None) -> dict[str, Any]:
    adapter_contract_ready = _runtime_stdio_self_test(runtime_self_test_argv)
    detail = (
        "Text Shortcuts IBus adapter is installed and the Rust stdio contract "
        "self-test passes; live IBus expansion still requires CI/qemu proof."
        if adapter_contract_ready
        else "Text Shortcuts IBus adapter is installed, but the Rust stdio "
        "contract self-test is not available in this session."
    )
    return {
        "ready": False,
        "adapter_contract_ready": adapter_contract_ready,
        "component": ADAPTER_PATH,
        "engine_name": ENGINE_NAME,
        "runtime": _runtime_binary(),
        "runtime_ready_claim": False,
        "detail": detail,
    }


def _table_path() -> str | None:
    config_home = os.environ.get("XDG_CONFIG_HOME")
    if not config_home:
        home = os.environ.get("HOME")
        if not home:
            return None
        config_home = os.path.join(home, ".config")
    if not config_home:
        return None
    return os.path.join(
        config_home,
        TEXT_SHORTCUTS_CONFIG_DIR,
        TEXT_SHORTCUTS_CONFIG_FILE,
    )


def _sanitize_shortcuts(raw: Any) -> list[dict[str, str]]:
    if not isinstance(raw, list):
        return []
    order: list[str] = []
    replacements: dict[str, str] = {}
    for entry in raw:
        if not isinstance(entry, dict):
            continue
        replace = str(entry.get("replace", "")).strip()
        with_text = str(entry.get("with", "")).strip()
        if not replace or not with_text or replace == with_text:
            continue
        if replace not in replacements:
            order.append(replace)
        replacements[replace] = with_text
    return [
        {"replace": replace, "with": replacements[replace]}
        for replace in order[:MAX_SHORTCUTS]
    ]


def _table_snapshot(path: str | None = None) -> tuple[str, list[dict[str, str]]]:
    table_path = path or _table_path()
    if table_path is None:
        return ("no-config-home", [])
    try:
        with open(table_path, "rb") as table_file:
            raw_bytes = table_file.read()
    except FileNotFoundError:
        return ("missing", [])
    except OSError:
        return ("unreadable", [])
    fingerprint = hashlib.sha256(raw_bytes).hexdigest()
    try:
        raw_shortcuts = json.loads(raw_bytes.decode("utf-8"))
    except (UnicodeDecodeError, json.JSONDecodeError):
        return (fingerprint, [])
    return (fingerprint, _sanitize_shortcuts(raw_shortcuts))


class ShortcutTableBridge:
    def __init__(self, path: str | None = None) -> None:
        self._path = path
        self._fingerprint: str | None = None

    def maybe_changed_request(self) -> dict[str, Any] | None:
        fingerprint, shortcuts = _table_snapshot(self._path)
        if fingerprint == self._fingerprint:
            return None
        self._fingerprint = fingerprint
        return {"type": "table-changed", "shortcuts": shortcuts}


def _candidate_metadata_from_response(response: dict[str, Any]) -> dict[str, Any] | None:
    candidate = response.get("candidate")
    if not isinstance(candidate, dict):
        return None
    replacement = candidate.get("replacement")
    accept_on = candidate.get("accept_on")
    dismiss_key = candidate.get("dismiss_key")
    rendered_bubble_ready_claim = candidate.get("rendered_bubble_ready_claim")
    if (
        not isinstance(replacement, str)
        or not replacement
        or not isinstance(accept_on, str)
        or accept_on != "word-boundary"
        or not isinstance(dismiss_key, str)
        or dismiss_key != "Escape"
        or rendered_bubble_ready_claim is not False
    ):
        return None
    return {
        "replacement": replacement,
        "accept_on": accept_on,
        "dismiss_key": dismiss_key,
        "rendered_bubble_ready_claim": False,
    }


def _candidate_clear_reason(response: dict[str, Any]) -> str:
    operations = response.get("operations", [])
    if not isinstance(operations, list):
        return "cleared"
    operation_types = {
        operation.get("type")
        for operation in operations
        if isinstance(operation, dict) and isinstance(operation.get("type"), str)
    }
    if "commit-text" in operation_types:
        return "committed"
    if "hide-preedit-text" in operation_types and response.get("handled") is True:
        return "dismissed"
    if "hide-preedit-text" in operation_types:
        return "hidden"
    return "cleared"


def _candidate_overlay_intent(
    action: str,
    metadata: dict[str, Any],
    reason: str,
) -> dict[str, Any]:
    return {
        "action": action,
        "replacement": metadata["replacement"],
        "accept_on": metadata["accept_on"],
        "dismiss_key": metadata["dismiss_key"],
        "reason": reason,
        "rendered_bubble_ready_claim": False,
        "live_overlay_claim": False,
        "runtime_ready_claim": False,
    }


def _candidate_bubble_frame_from_intent(intent: dict[str, Any]) -> dict[str, Any] | None:
    action = intent.get("action")
    replacement = intent.get("replacement")
    accept_on = intent.get("accept_on")
    dismiss_key = intent.get("dismiss_key")
    reason = intent.get("reason")
    if (
        action not in {"show-candidate", "hide-candidate"}
        or not isinstance(replacement, str)
        or not replacement
        or accept_on != "word-boundary"
        or dismiss_key != "Escape"
        or not isinstance(reason, str)
        or intent.get("rendered_bubble_ready_claim") is not False
        or intent.get("live_overlay_claim") is not False
        or intent.get("runtime_ready_claim") is not False
    ):
        return None
    return {
        "surface": ACCEPT_BUBBLE_FRAME_SURFACE,
        "action": action,
        "replacement": replacement,
        "accept_on": accept_on,
        "accept_keys": ["Space", "Return"],
        "dismiss_key": dismiss_key,
        "reason": reason,
        "style_class": ACCEPT_BUBBLE_STYLE_CLASS,
        "text_style_class": ACCEPT_BUBBLE_TEXT_STYLE_CLASS,
        "hint_style_class": ACCEPT_BUBBLE_HINT_STYLE_CLASS,
        "font_family": "Inter",
        "rendered_bubble_ready_claim": False,
        "live_overlay_claim": False,
        "runtime_ready_claim": False,
    }


def _candidate_bubble_frames_from_overlay_intents(
    intents: list[dict[str, Any]],
) -> list[dict[str, Any]]:
    frames: list[dict[str, Any]] = []
    for intent in intents:
        frame = _candidate_bubble_frame_from_intent(intent)
        assert frame is not None
        frames.append(frame)
    return frames


class CandidateMetadataState:
    def __init__(self) -> None:
        self.current: dict[str, Any] | None = None
        self.last_overlay_intent: dict[str, Any] | None = None

    def observe_response(self, response: dict[str, Any]) -> None:
        previous = self.current
        candidate = _candidate_metadata_from_response(response)
        if candidate is not None:
            self.current = candidate
            self.last_overlay_intent = _candidate_overlay_intent(
                "show-candidate",
                candidate,
                "candidate-visible",
            )
            return
        self.current = None
        if previous is not None:
            self.last_overlay_intent = _candidate_overlay_intent(
                "hide-candidate",
                previous,
                _candidate_clear_reason(response),
            )
        else:
            self.last_overlay_intent = None

    def clear(self, reason: str = "cleared") -> None:
        previous = self.current
        self.current = None
        if previous is not None:
            self.last_overlay_intent = _candidate_overlay_intent(
                "hide-candidate",
                previous,
                reason,
            )
        else:
            self.last_overlay_intent = None


class RuntimeBridge:
    def __init__(
        self,
        argv: list[str] | None = None,
        response_timeout: float = RESPONSE_TIMEOUT_SECONDS,
    ) -> None:
        self._argv = argv or _runtime_argv()
        self._response_timeout = response_timeout
        self._process: subprocess.Popen[str] | None = None
        self._disabled = False

    def send(self, request: dict[str, Any]) -> dict[str, Any]:
        if self._disabled:
            return _passthrough_response()
        process = self._ensure_process()
        if process is None or process.stdin is None or process.stdout is None:
            return _passthrough_response()
        try:
            process.stdin.write(json.dumps(request, separators=(",", ":")) + "\n")
            process.stdin.flush()
            readable, _, _ = select.select(
                [process.stdout], [], [], self._response_timeout
            )
            if not readable:
                self._disable("runtime did not answer before timeout")
                return _passthrough_response()
            line = process.stdout.readline()
            if not line:
                self._disable("runtime closed stdout")
                return _passthrough_response()
            response = json.loads(line)
            if not isinstance(response, dict):
                self._disable("runtime returned non-object JSON")
                return _passthrough_response()
            return response
        except (BrokenPipeError, OSError, json.JSONDecodeError) as error:
            self._disable(f"runtime bridge failed: {error}")
            return _passthrough_response()

    def close(self) -> None:
        process = self._process
        self._process = None
        if process is None:
            return
        process.terminate()
        try:
            process.wait(timeout=0.5)
        except subprocess.TimeoutExpired:
            process.kill()
            process.wait(timeout=0.5)

    def _ensure_process(self) -> subprocess.Popen[str] | None:
        if self._process is not None and self._process.poll() is None:
            return self._process
        try:
            self._process = subprocess.Popen(
                self._argv,
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                text=True,
                encoding="utf-8",
            )
        except OSError as error:
            self._disable(f"could not start runtime: {error}")
            return None
        return self._process

    def _disable(self, message: str) -> None:
        print(f"goblins-textshortcuts-ibus: {message}", file=sys.stderr)
        self._disabled = True
        self.close()


def _passthrough_response() -> dict[str, Any]:
    return {"handled": False, "operations": [], "error": None}


def _key_request(keyval: int, state: int, ibus: Any) -> dict[str, Any]:
    release_mask = int(getattr(ibus.ModifierType, "RELEASE_MASK", 1 << 30))
    pressed = (state & release_mask) == 0
    return {
        "type": "key",
        "keyval": int(keyval),
        "unicode": _unicode_for_keyval(keyval, ibus) if pressed else None,
        "pressed": pressed,
        "command_modifier_active": _command_modifier_active(state, ibus),
    }


def _unicode_for_keyval(keyval: int, ibus: Any) -> str | None:
    codepoint = int(ibus.keyval_to_unicode(keyval))
    if codepoint < 0x20 or codepoint > 0x10FFFF:
        return None
    return chr(codepoint)


def _command_modifier_active(state: int, ibus: Any) -> bool:
    modifiers = (
        "CONTROL_MASK",
        "META_MASK",
        "MOD1_MASK",
        "MOD4_MASK",
        "SUPER_MASK",
        "HYPER_MASK",
    )
    for name in modifiers:
        value = getattr(ibus.ModifierType, name, None)
        if value is not None and state & int(value):
            return True
    return False


def _content_purpose_request(event_type: str, purpose: int) -> dict[str, Any]:
    return {"type": event_type, "purpose": int(purpose)}


def _send_table_changed_if_needed(
    table_bridge: ShortcutTableBridge,
    runtime_bridge: RuntimeBridge,
    target: Any,
    text_factory: Callable[[str], Any],
    candidate_state: CandidateMetadataState | None = None,
) -> None:
    request = table_bridge.maybe_changed_request()
    if request is None:
        return
    _apply_response_operations(
        target,
        runtime_bridge.send(request),
        text_factory,
        candidate_state,
    )


def _apply_response_operations(
    target: Any,
    response: dict[str, Any],
    text_factory: Callable[[str], Any],
    candidate_state: CandidateMetadataState | None = None,
) -> None:
    if candidate_state is not None:
        candidate_state.observe_response(response)
    operations = response.get("operations", [])
    if not isinstance(operations, list):
        return
    for operation in operations:
        if not isinstance(operation, dict):
            continue
        operation_type = operation.get("type")
        if operation_type == "update-preedit-text":
            target.update_preedit_text(
                text_factory(str(operation.get("text", ""))),
                int(operation.get("cursor_pos", 0)),
                bool(operation.get("visible", False)),
            )
        elif operation_type == "hide-preedit-text":
            target.hide_preedit_text()
        elif operation_type == "delete-surrounding-text":
            target.delete_surrounding_text(
                int(operation.get("offset", 0)),
                int(operation.get("n_chars", 0)),
            )
        elif operation_type == "commit-text":
            target.commit_text(text_factory(str(operation.get("text", ""))))


def _run_self_test() -> None:
    class FakeModifierType:
        RELEASE_MASK = 1 << 30
        CONTROL_MASK = 1 << 2
        MOD1_MASK = 1 << 3
        MOD4_MASK = 1 << 6

    class FakeIbus:
        ModifierType = FakeModifierType

        @staticmethod
        def keyval_to_unicode(keyval: int) -> int:
            if keyval == 0xFF0D:
                return 0
            return keyval

    assert _key_request(ord("o"), 0, FakeIbus) == {
        "type": "key",
        "keyval": ord("o"),
        "unicode": "o",
        "pressed": True,
        "command_modifier_active": False,
    }
    assert _key_request(ord("o"), FakeModifierType.RELEASE_MASK, FakeIbus)[
        "pressed"
    ] is False
    assert _key_request(ord("w"), FakeModifierType.CONTROL_MASK, FakeIbus)[
        "command_modifier_active"
    ] is True
    assert _key_request(0xFF0D, 0, FakeIbus)["unicode"] is None
    assert _content_purpose_request("content-purpose-changed", 9) == {
        "type": "content-purpose-changed",
        "purpose": 9,
    }
    assert _candidate_metadata_from_response(
        {
            "candidate": {
                "replacement": "on my way",
                "accept_on": "word-boundary",
                "dismiss_key": "Escape",
                "rendered_bubble_ready_claim": False,
            }
        }
    ) == {
        "replacement": "on my way",
        "accept_on": "word-boundary",
        "dismiss_key": "Escape",
        "rendered_bubble_ready_claim": False,
    }
    assert _candidate_metadata_from_response(
        {
            "candidate": {
                "replacement": "on my way",
                "accept_on": "word-boundary",
                "dismiss_key": "Escape",
                "rendered_bubble_ready_claim": True,
            }
        }
    ) is None

    class FakeTarget:
        def __init__(self) -> None:
            self.calls: list[tuple[Any, ...]] = []

        def update_preedit_text(self, text: str, cursor_pos: int, visible: bool) -> None:
            self.calls.append(("update", text, cursor_pos, visible))

        def hide_preedit_text(self) -> None:
            self.calls.append(("hide",))

        def delete_surrounding_text(self, offset: int, n_chars: int) -> None:
            self.calls.append(("delete", offset, n_chars))

        def commit_text(self, text: str) -> None:
            self.calls.append(("commit", text))

    target = FakeTarget()
    candidate_state = CandidateMetadataState()
    _apply_response_operations(
        target,
        {
            "handled": False,
            "operations": [
                {
                    "type": "update-preedit-text",
                    "text": "on my way",
                    "cursor_pos": 9,
                    "visible": True,
                }
            ],
            "candidate": {
                "replacement": "on my way",
                "accept_on": "word-boundary",
                "dismiss_key": "Escape",
                "rendered_bubble_ready_claim": False,
            },
        },
        lambda text: text,
        candidate_state,
    )
    assert candidate_state.current == {
        "replacement": "on my way",
        "accept_on": "word-boundary",
        "dismiss_key": "Escape",
        "rendered_bubble_ready_claim": False,
    }
    assert candidate_state.last_overlay_intent == {
        "action": "show-candidate",
        "replacement": "on my way",
        "accept_on": "word-boundary",
        "dismiss_key": "Escape",
        "reason": "candidate-visible",
        "rendered_bubble_ready_claim": False,
        "live_overlay_claim": False,
        "runtime_ready_claim": False,
    }
    _apply_response_operations(
        target,
        {
            "handled": True,
            "operations": [{"type": "hide-preedit-text"}],
        },
        lambda text: text,
        candidate_state,
    )
    assert candidate_state.current is None
    assert candidate_state.last_overlay_intent == {
        "action": "hide-candidate",
        "replacement": "on my way",
        "accept_on": "word-boundary",
        "dismiss_key": "Escape",
        "reason": "dismissed",
        "rendered_bubble_ready_claim": False,
        "live_overlay_claim": False,
        "runtime_ready_claim": False,
    }
    bubble_frame = _candidate_bubble_frame_from_intent(
        candidate_state.last_overlay_intent
    )
    assert bubble_frame == {
        "surface": ACCEPT_BUBBLE_FRAME_SURFACE,
        "action": "hide-candidate",
        "replacement": "on my way",
        "accept_on": "word-boundary",
        "accept_keys": ["Space", "Return"],
        "dismiss_key": "Escape",
        "reason": "dismissed",
        "style_class": ACCEPT_BUBBLE_STYLE_CLASS,
        "text_style_class": ACCEPT_BUBBLE_TEXT_STYLE_CLASS,
        "hint_style_class": ACCEPT_BUBBLE_HINT_STYLE_CLASS,
        "font_family": "Inter",
        "rendered_bubble_ready_claim": False,
        "live_overlay_claim": False,
        "runtime_ready_claim": False,
    }

    target = FakeTarget()
    _apply_response_operations(
        target,
        {
            "handled": True,
            "operations": [
                {
                    "type": "update-preedit-text",
                    "text": "On my way!",
                    "cursor_pos": 10,
                    "visible": True,
                },
                {"type": "delete-surrounding-text", "offset": -3, "n_chars": 3},
                {"type": "commit-text", "text": "On my way!"},
                {"type": "hide-preedit-text"},
            ],
            "candidate": {
                "replacement": "On my way!",
                "accept_on": "word-boundary",
                "dismiss_key": "Escape",
                "rendered_bubble_ready_claim": False,
            },
        },
        lambda text: text,
    )
    assert target.calls == [
        ("update", "On my way!", 10, True),
        ("delete", -3, 3),
        ("commit", "On my way!"),
        ("hide",),
    ]

    payload = capability_payload(["/bin/false"])
    assert payload["ready"] is False
    assert payload["adapter_contract_ready"] is False
    assert payload["runtime_ready_claim"] is False
    assert payload["component"] == ADAPTER_PATH

    assert _sanitize_shortcuts(
        [
            {"replace": "  omw ", "with": " on my way "},
            {"replace": "same", "with": "same"},
            {"replace": "", "with": "drop"},
            {"replace": "drop", "with": ""},
            {"replace": "omw", "with": "on my way now"},
            "not an entry",
        ]
    ) == [{"replace": "omw", "with": "on my way now"}]

    with tempfile.TemporaryDirectory() as tmpdir:
        table_path = os.path.join(tmpdir, "text-shortcuts.json")
        table_bridge = ShortcutTableBridge(table_path)
        assert table_bridge.maybe_changed_request() == {
            "type": "table-changed",
            "shortcuts": [],
        }
        assert table_bridge.maybe_changed_request() is None
        with open(table_path, "w", encoding="utf-8") as table_file:
            json.dump(
                [
                    {"replace": "omw", "with": "on my way"},
                    {"replace": "teh", "with": "the"},
                ],
                table_file,
            )
        assert table_bridge.maybe_changed_request() == {
            "type": "table-changed",
            "shortcuts": [
                {"replace": "omw", "with": "on my way"},
                {"replace": "teh", "with": "the"},
            ],
        }
        assert table_bridge.maybe_changed_request() is None


def _key_protocol_event(character: str) -> dict[str, Any]:
    return {
        "type": "key",
        "keyval": ord(character),
        "unicode": character,
        "pressed": True,
        "command_modifier_active": False,
    }


def _special_key_protocol_event(keyval: int) -> dict[str, Any]:
    return {
        "type": "key",
        "keyval": keyval,
        "unicode": None,
        "pressed": True,
        "command_modifier_active": False,
    }


def _overlay_intent_proof_payload(intents: list[dict[str, Any]]) -> dict[str, Any]:
    show_count = sum(1 for intent in intents if intent.get("action") == "show-candidate")
    hide_count = sum(1 for intent in intents if intent.get("action") == "hide-candidate")
    return {
        "status": "pass",
        "surface": OVERLAY_INTENT_PROOF_SURFACE,
        "intents": intents,
        "show_count": show_count,
        "hide_count": hide_count,
        "rendered_bubble_ready_claim": False,
        "live_overlay_claim": False,
        "runtime_ready_claim": False,
    }


def _assert_overlay_intent(intent: dict[str, Any] | None, action: str, reason: str) -> dict[str, Any]:
    assert intent is not None
    assert intent["action"] == action
    assert intent["replacement"] == "on my way"
    assert intent["accept_on"] == "word-boundary"
    assert intent["dismiss_key"] == "Escape"
    assert intent["reason"] == reason
    assert intent["rendered_bubble_ready_claim"] is False
    assert intent["live_overlay_claim"] is False
    assert intent["runtime_ready_claim"] is False
    return dict(intent)


def _candidate_bubble_frame_proof_payload(
    intents: list[dict[str, Any]],
) -> dict[str, Any]:
    frames = _candidate_bubble_frames_from_overlay_intents(intents)
    show_frame_count = sum(
        1 for frame in frames if frame.get("action") == "show-candidate"
    )
    hide_frame_count = sum(
        1 for frame in frames if frame.get("action") == "hide-candidate"
    )
    return {
        "status": "pass",
        "surface": ACCEPT_BUBBLE_FRAME_SURFACE,
        "frames": frames,
        "show_frame_count": show_frame_count,
