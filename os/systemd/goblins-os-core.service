[Unit]
Description=Goblins OS local AI service core
After=network-online.target
Wants=network-online.target
# Every Settings/status surface depends on this daemon; a one-off death must
# never become a permanent outage through restart rate limiting.
StartLimitIntervalSec=0

[Service]
Type=simple
User=goblins-os
Group=goblins-os
SupplementaryGroups=goblins-session-bridge goblins-core-resident
EnvironmentFile=-/etc/goblins-os/environment
LoadCredential=openai-secrets.env:/etc/goblins-os/openai-secrets.env
ExecStart=/usr/libexec/goblins-os/goblins-os-core
Restart=always
RestartSec=2s
# Back off toward a calm retry cadence when the failure persists; the unit
# keeps retrying (never latches failed) without flooding the journal.
RestartSteps=8
RestartMaxDelaySec=60
StateDirectory=goblins-os/models goblins-os/ai goblins-os/policy
StateDirectoryMode=0750
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/var/lib/goblins-os/installer /var/lib/goblins-os/session /var/lib/goblins-os/policy /var/lib/goblins-os/ai /var/lib/goblins-os/models /var/lib/goblins-os/secrets/openai /var/lib/goblins-os/apps /var/lib/goblins-os/codex
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
SystemCallArchitectures=native

[Install]
WantedBy=multi-user.target
