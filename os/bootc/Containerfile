LABEL org.goblins-os.supported-architectures="x86_64,aarch64"

RUN image_arch="$(rpm --eval '%{_arch}')" \
    && machine_arch="$(uname -m)" \
    && case "${machine_arch}" in \
      x86_64|aarch64) ;; \
      *) echo "Goblins OS native images support only x86_64 and aarch64; got ${machine_arch}" >&2; exit 1 ;; \
    esac \
    && case "${image_arch}" in \
      x86_64|aarch64) ;; \
      *) echo "Fedora RPM architecture must be x86_64 or aarch64; got ${image_arch}" >&2; exit 1 ;; \
    esac \
    && test "${machine_arch}" = "${image_arch}"

