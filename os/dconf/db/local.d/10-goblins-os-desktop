# Goblins OS desktop defaults — the macOS-blend chrome at the GNOME level.
# Compiled into the system dconf db (system-db:local) and applied to the desktop
# user via os/dconf/profile/user. These are defaults; the person can change them.

[org/gnome/desktop/background]
picture-uri='file:///usr/share/goblins-os/brand/wallpaper/goblins-os-light.png'
picture-uri-dark='file:///usr/share/goblins-os/brand/wallpaper/goblins-os-dark.png'
picture-options='zoom'
primary-color='#0b0b11'
secondary-color='#0b0b11'

[org/gnome/desktop/screensaver]
picture-uri='file:///usr/share/goblins-os/brand/wallpaper/goblins-os-dark.png'
picture-options='zoom'

[org/gnome/desktop/interface]
# Goblins-calm: Inter everywhere, a neutral (slate) accent, Light by default with
# Auto/Dark a switch away — the whole OS themes from one scheme key.
color-scheme='default'
accent-color='slate'
icon-theme='GoblinsOS'
font-name='Inter 11'
document-font-name='Inter 11'
font-antialiasing='rgba'
font-hinting='slight'
enable-animations=true

[org/gnome/desktop/sound]
theme-name='GoblinsOS'
event-sounds=true
input-feedback-sounds=false

[org/gnome/desktop/wm/preferences]
# macOS-style: window controls on the LEFT, none on the right.
button-layout='close,minimize,maximize:'
titlebar-font='Inter 11'

[org/gnome/mutter]
# Keep GNOME's real compositor/window manager doing the hard work, but tune the
# user-facing behavior toward the Goblins/macOS model: centered new windows,
# dynamic workspaces, edge snap-assist, and no multi-monitor workspace surprise.
center-new-windows=true
dynamic-workspaces=true
edge-tiling=true
workspaces-only-on-primary=true

[org/gnome/desktop/wm/keybindings]
# Free Cmd/Super+Space for the launcher. Goblins seeds a single IBus engine as
# the default source, so there is no stock source switcher to expose by default.
switch-input-source=@as []
switch-input-source-backward=@as []
# Free <Super>Tab so the Goblins window-switcher (goblins-wm) owns it cleanly —
# GNOME's switch-applications defaults to <Super>Tab and would collide otherwise.
switch-applications=@as []
switch-applications-backward=@as []
# Show Desktop — push all windows aside to reveal the desktop, the macOS
# spread-thumbs / F11 reflex. Bound on the WM's stable, built-in action (no custom
# code), so it tracks GNOME with zero maintenance.
show-desktop=['<Super>d']

[org/gnome/settings-daemon/plugins/media-keys]
# Super+Space opens the bespoke Goblins launcher (Spotlight); Super+Shift+Space
# opens the same surface in assistant-first mode. Super+Alt+Space opens the
# selected-text context action, Super+Alt+W opens writing tools, Super+Alt+S opens screen context, and
# Super+Alt+V opens screenshot/visual context. The MediaKeys settings-daemon
# plugin is a RequiredComponent of the goblins-os session, so these bindings
# are live in the session.
custom-keybindings=['/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-launcher/','/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-assistant/','/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-selected-text/','/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-writing-tools/','/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-screen-context/','/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-visual-context/','/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-dictate/','/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-color-picker/']
# macOS screenshot muscle-memory on GNOME's own (Wayland-correct) capture stack.
# Cmd+Shift+3 → whole screen saved to ~/Pictures/Screenshots; +Ctrl → clipboard
# (macOS uses Control to divert to the clipboard). Cmd+Shift+4/5 live below in the
# shell-keybindings group (the interactive capture/record overlay).
screenshot=['<Shift><Super>3']
screenshot-clip=['<Shift><Super><Control>3']

[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-launcher]
name='Goblins Launcher'
command='/usr/libexec/goblins-os/goblins-os-launcher'
binding='<Super>space'

[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-assistant]
name='Goblins AI'
command='/usr/libexec/goblins-os/goblins-os-launcher --assistant'
binding='<Super><Shift>space'

[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-selected-text]
name='Goblins AI Selected Text'
command='/usr/libexec/goblins-os/goblins-os-launcher --selected-text'
binding='<Super><Alt>space'

[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-writing-tools]
name='Goblins AI Writing Tools'
command='/usr/libexec/goblins-os/goblins-os-launcher --writing-tools'
binding='<Super><Alt>w'

[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-screen-context]
name='Goblins AI Screen Context'
command='/usr/libexec/goblins-os/goblins-os-launcher --screen-context'
binding='<Super><Alt>s'

[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-visual-context]
name='Goblins AI Screenshot Context'
command='/usr/libexec/goblins-os/goblins-os-screenshot-context'
binding='<Super><Alt>v'

# Dictation — speak into the focused text field. Captures + transcribes on-device
# (Whisper) via the local core, then types the result with wtype. Honest-gates
# (types nothing) when no microphone / Whisper model is present.
[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-dictate]
name='Goblins Dictation'
command='/usr/libexec/goblins-os/goblins-os-dictate'
binding='<Super><Alt>d'

# Color picker — pick any pixel via the desktop portal's magnified loupe; the
# exact color lands on the clipboard (HEX) with a calm toast. <Alt> avoids the
# screenshot-clip <Control> chord.
[org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/goblins-color-picker]
name='Goblins Color Picker'
command='/usr/libexec/goblins-os/goblins-os-color-picker'
binding='<Super><Alt>c'

[org/gnome/shell/keybindings]
# The interactive capture overlay (area/window/screen toggle + record button +
# selection handles + clipboard copy) is GNOME's native Cmd+Shift+5 equivalent.
# Cmd+Shift+4 → capture (defaults to area; press W for window, S for screen);
# Cmd+Shift+5 → the same overlay switched to screen-recording. Print still works.
show-screenshot-ui=['<Shift><Super>4', 'Print']
show-screen-recording-ui=['<Shift><Super>5']

[org/gnome/shell]
# Desktop surfaces: the GoblinsOS theme (menu bar / control center) + our
# own overview-independent dock (dash-to-dock needs the overview, which this mode
# strips out). Version validation off as belt-and-suspenders for bundled extensions.
enabled-extensions=['user-theme@gnome-shell-extensions.gcampax.github.com', 'gsconnect@andyholmes.github.io', 'goblins-dock@goblins.os', 'goblins-menubar@goblins.os', 'goblins-wm@goblins.os']
disable-extension-version-validation=true
# The dock's pinned surfaces (Build Studio + Settings). The Home IS the shell, so
# it is not pinned; built apps and utilities join the dock when running.
favorite-apps=['org.goblins.OS.OpenAI.Codex.desktop', 'org.gnome.Nautilus.desktop', 'org.gnome.Console.desktop', 'org.goblins.OS.Settings.desktop']

[org/gnome/shell/extensions/user-theme]
name='GoblinsOS'

[org/freedesktop/ibus/general]
preload-engines=['goblins-textshortcuts']

[org/gnome/desktop/input-sources]
sources=[('ibus', 'goblins-textshortcuts')]
mru-sources=[('ibus', 'goblins-textshortcuts')]
per-window=false
show-all-sources=false
